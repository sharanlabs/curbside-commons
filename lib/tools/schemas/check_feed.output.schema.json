{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://activationops.local/tools/check_feed.output.schema.json",
  "title": "check_feed output envelope",
  "type": "object",
  "additionalProperties": false,
  "required": ["tool", "ok", "exitCode", "canonical"],
  "properties": {
    "tool": { "const": "check_feed" },
    "ok": { "type": "boolean" },
    "exitCode": { "type": "integer", "enum": [0, 1] },
    "demoOnly": { "type": "boolean", "const": false },
    "advisory": { "type": "boolean", "const": false },
    "earnsLabel": { "type": "boolean" },
    "canonical": { "type": "string", "minLength": 1 }
  }
}
