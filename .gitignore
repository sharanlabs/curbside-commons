.next/
next-env.d.ts
coverage/
*.tsbuildinfo
.vercel/

# Playwright (Phase C)
playwright-report/
test-results/

# UI-redesign exploration screenshots — regenerable (large PNGs); the source mockups/*.html are tracked.
mockups/shots/

# Harness/session scaffolding (2026-07-03) — machine-local Claude Code artifacts, not product source.
