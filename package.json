{
  "name": "activationops-ai",
  "version": "0.1.0",
  "private": true,
  "description": "Merchant activation AI for a local-commerce delivery marketplace: deterministic triage + explainable blocker diagnosis + eval-gated bounded Gemini outreach drafting + claims gatekeeper + human-approval gate + audit. Company-agnostic prototype on hybrid (real open-source entities + synthetic activation) data.",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint . --max-warnings=0",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:legacy": "vitest run legacy/activation/evals",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "coverage": "vitest run --coverage",
    "verify": "npm run typecheck && npm run lint && npm run test && npm run build",
    "verify:full": "npm run verify && npm run test:e2e"
  },
  "dependencies": {
    "@ai-sdk/google": "^2.0.11",
    "@ai-sdk/groq": "^2.0.42",
    "ai": "^5.0.98",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.555.0",
    "next": "^16.0.6",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "tailwind-merge": "^3.4.0",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@playwright/test": "^1.61.0",
    "@tailwindcss/postcss": "^4.1.17",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitest/coverage-v8": "^4.1.5",
    "eslint": "^9.39.1",
    "eslint-config-next": "^16.0.6",
    "jsdom": "^27.2.0",
    "tailwindcss": "^4.1.17",
    "typescript": "^5.9.3",
    "vitest": "^4.0.14"
  }
}
