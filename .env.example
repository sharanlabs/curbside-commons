# ───────────────────────────────────────────────────────────────────────────────
# ActivationOps AI — environment template (TRACKED; contains NO real secrets).
#
# HOW TO USE (the "space to paste your keys"):
#   1. Copy this file to `.env`            →  cp .env.example .env
#      (If `.env` already exists, DON'T overwrite it — just open it and add/update
#       the keys below. `.env` holds your real keys and is gitignored.)
#   2. Open `.env` in your editor and paste your real keys after the `=` signs.
#   3. NEVER paste a real key into chat, a commit, a log, or a screenshot (RULES §11).
#      `.env` is gitignored (.gitignore: `.env`, `.env*.local`) and must stay untracked.
#
# Verify before any live run:   git check-ignore .env   (must print ".env")
#                               git status               (must NOT list .env)
# ───────────────────────────────────────────────────────────────────────────────

# ── API KEYS (paste yours into .env) ─────────────────────────────────────────────

# Gemini — the live DRAFTER (the only METERED path; A3-7 live run, $5 hard cap).
# Get one at https://aistudio.google.com/apikey . Leave blank = deterministic REPLAY/mock, $0.
GEMINI_API_KEY=

# Groq — the cross-family JUDGES (faithfulness + domain) AND the Groq agents
# (Strategist / Router / the A2 Groq drafter). FREE tier (200K tokens/day).
# Get one at https://console.groq.com/keys . Leave blank = deterministic mock judges, $0.
GROQ_API_KEY=

# ── MASTER SWITCH ────────────────────────────────────────────────────────────────

# The single gate for ALL live AI. Off by default and off in the public deploy
# (REPLAY-only, can never spend). Set to `true` ONLY for an intentional live run.
#   true | 1 | yes | on  = live enabled (still needs the relevant key present)
ENABLE_LIVE_AI=false

# ── CROSS-FAMILY PROVIDER SELECTORS (defaults are correct — leave as `groq`) ──────
# maker≠judge at the model layer (R-ARCH-3): the Drafter is Gemini, BOTH critics are
# Groq. Flipping either to `gemini` makes that critic SAME-family as the drafter —
# the loop's live gate REQUIRES both to resolve to `groq` (a forced live:true that
# isn't cross-family-ready THROWS). Keep these `groq` for the A3-7 cross-family run.
JUDGE_PROVIDER=groq
DOMAIN_JUDGE_PROVIDER=groq

# ── OPTIONAL MODEL OVERRIDES (leave blank to use the code's freshness-checked defaults) ──
# Model ids are re-verified against current official docs at use-time (RULES §6),
# never pinned from memory. Only set these to override the default.
GEMINI_MODEL=
GROQ_DRAFT_MODEL=
JUDGE_MODEL=
DOMAIN_JUDGE_MODEL=
FEE_CLASSIFIER_MODEL=

# Optional pricing-snapshot freshness date (ISO, e.g. 2026-06-28); informational.
FETCHED_AT=

# ═════════════════════════════════════════════════════════════════════════════════
# QUICK SETUPS
#
#  • A3-7 live cross-family run (Gemini drafter + Groq critics, within the $5 cap):
#       GEMINI_API_KEY=<your gemini key>
#       GROQ_API_KEY=<your groq key>
#       ENABLE_LIVE_AI=true
#       JUDGE_PROVIDER=groq         (default)
#       DOMAIN_JUDGE_PROVIDER=groq  (default)
#     ⚠️ A3-7 is OWNER-GATED: live spend — confirm the $5 cap + a live Gemini
#        model-id/pricing freshness check (RULES §6) + a Codex cross-check first.
#
#  • Groq-only evals (judges/Strategist/Router live, $0 free tier — no Gemini):
#       GROQ_API_KEY=<your groq key>
#       ENABLE_LIVE_AI=true
#
#  • Default (no keys): everything runs deterministic REPLAY/mock at $0.
# ═════════════════════════════════════════════════════════════════════════════════
