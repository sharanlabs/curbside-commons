# Optional. Without this, ActivationOps AI runs in deterministic REPLAY/demo mode
# (no live AI calls, no spend). The public demo is REPLAY-only by design.
GEMINI_API_KEY=

# Set to true to call bounded, schema-constrained Gemini drafting instead of the
# deterministic replay/mock. Off by default (and off in the public deploy).
ENABLE_LIVE_AI=false

# Optional. The Gemini model id is re-verified against current official docs at
# use-time (RULES §6) and never pinned from memory. Leave blank to use the
# code's preflight-checked default.
GEMINI_MODEL=
