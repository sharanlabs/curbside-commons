  color: var(--gold-text);
  padding-top: 3px;
}
.cc-note-idx-sr {
  position: absolute;
  width: 1px;
  height: 1px;
  padding: 0;
  margin: -1px;
  overflow: hidden;
  clip: rect(0 0 0 0);
  white-space: nowrap;
  border: 0;
}
.cc-note-title {
  margin: 0;
  font-family: var(--serif);
  font-size: 19px;
  line-height: 1.25;
  color: var(--ink);
}
.cc-note-body {
  margin: 8px 0 0;
  font-size: 15px;
  line-height: 1.55;
  color: var(--body);
  max-width: 56ch;
}

