/* ----- 03 COVERAGE: the tablist -------------------------------------------- */
.cv {
  margin-top: 30px;
}
.cv-tabs {
  display: flex;
  flex-wrap: wrap;
  gap: 4px;
  border-bottom: 1px solid var(--rule-2);
}
.cv-tab {
  position: relative;
  font-size: 11.5px;
  font-weight: 700;
  letter-spacing: 0.08em;
  color: var(--muted);
  background: none;
  border: 0;
  padding: 12px 14px;
  cursor: pointer;
  transition: color 0.18s var(--ease);
}
.cv-tab::after {
  content: "";
  position: absolute;
  left: 10px;
  right: 10px;
  bottom: -1px;
  height: 2px;
  background: var(--iris);
  transform: scaleX(0);
  transition: transform 0.22s var(--ease);
}
.cv-tab:hover {
  color: var(--ink-2);
}
.cv-tab[aria-selected="true"] {
  color: var(--iris-ink);
}
.cv-tab[aria-selected="true"]::after {
  transform: scaleX(1);
}
.cv-tab:focus-visible {
  outline: 2px solid var(--iris-ink);
  outline-offset: -2px;
  border-radius: 3px;
}
.cv-panel {
  padding: 22px 2px 0;
}
.cv-panel:focus-visible {
  outline: 2px solid var(--iris-ink);
  outline-offset: 4px;
  border-radius: 4px;
}
.cv-panel-body {
  margin: 0;
  font-size: clamp(16px, 1.8vw, 18.5px);
  line-height: 1.6;
  color: var(--body);
  max-width: 60ch;
}

/* ----- 04 LIMITS: sticky thesis + numbered margin notes -------------------- */
.cc-limits-grid {
  display: grid;
  grid-template-columns: 0.9fr 1.1fr;
  gap: clamp(28px, 6vw, 88px);
  align-items: start;
}
.cc-limits-thesis {
  position: sticky;
  top: 96px;
}
.cc-limits-notes {
  list-style: none;
  margin: 0;
  padding: 0;
}
.cc-note {
  display: grid;
  grid-template-columns: auto 1fr;
  gap: 18px;
  padding: 22px 0;
