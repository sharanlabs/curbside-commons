/* ============================================================================
   THE REPORT / DEMO DOCUMENT SYSTEM — re-tokened for the redesign B1 (2026-07-14).
   Scoped to the two real verifier surfaces (/report + /demo, both mount .rpt-wrap);
   the landing keeps its own system. Spec: docs/design-brief-redesign-2026-07-14.md.
   Lineage: the "Ledger" audit-certificate STRUCTURE (Swiss / International-
   Typographic; flat, no radii / shadows / gradients; the precision of the hairline
   rules and the spacing IS the design) is RETAINED; the token VALUES move in
   lockstep to the new site system.

   B1 re-token: off-white ground #FBFBFD → pure white #FFFFFF; the ink ramp moves to
   the new near-neutral values; the accent → DEEP ember #C0341C (the token NAME --um
   is kept so every consumer follows) — used on the masthead rule · finding index
   numerals, NEVER on severity. Severity carries its own three marks (error / warn /
   info) kept perceptually far from the brand, always paired with a square shape +
   word. Display headings adopt the site display voice (Onest, storyboard adoption
   2026-07-15); body + receipts adopt Onest / JetBrains Mono. Honesty freeze-reversal (Slice D,
   decision-log 2026-07-14): the SIMULATED banner was removed — the page is
   disclaimer-free (no false claim; C10 green).
   Contrast recomputed on #FFFFFF (ratios in the token comments below).
   Desktop web + printable (see the @media print block below). rpt-* / dmo-*.
   ========================================================================== */
.rpt-wrap {
  /* Redesign B1 re-token (2026-07-14): the Ledger STRUCTURE is retained; every local
     token VALUE is moved IN LOCKSTEP to the new :root system (this block is insulated
     from :root, so it must mirror by hand). Kept as ONE --paper token so every
     text-on-ink surface (banner text, verdict flag) follows automatically. Contrast
     recomputed on the pure-white #ffffff ground (standard WCAG sRGB). */
  --paper: #ffffff; /* pure-white ground + every text-on-ink surface (banner text, verdict flag) */
  --ink: #12141c; /* near-black: headline, banner ground, verdict stamp, hard marks — 18.38:1 */
  --body: #3b3f4b; /* long-form body text — 10.51:1 (sitewide body ramp) */
  --graphite: #4a4e5a; /* rail captions, labels, secondary mono — 8.31:1 */
  --hairline: rgba(18, 20, 28, 0.13); /* low-alpha ink modular-grid rules (site --rule family) */
  --um: #2438d6; /* the accent — ULTRAMARINE (token NAME kept; v8 design adoption
     2026-07-16, lockstep with :root --accent); --paper on --um = 8.04:1 */
  --sev-err: #d92d20; /* 4.83:1 — kept perceptually far from the brand via shape + word */
  --sev-warn: #b54708; /* 5.43:1 — amber */
  --sev-info: #605c68; /* neutral — 6.51:1 (no info in the fixture; never a brand/alarm hue) */
  /* font stacks now adopt the self-hosted site fonts (Onest display + body,
     JetBrains mono) so the report matches the site register; kept self-defined
     so nothing here falls through to :root. */
  --serif: var(--font-sans), "Onest", ui-rounded, system-ui, sans-serif;
  --ledger-sans: var(--font-sans), "Onest", ui-rounded, system-ui, -apple-system, "Segoe UI", sans-serif;
  --ledger-mono: var(--font-mono), ui-monospace, SFMono-Regular, "JetBrains Mono", Menlo,
    monospace;

  max-width: 1180px;
  margin: 0 auto;
  padding: 48px 64px 120px;
  background: var(--paper);
  color: var(--body);
  font-family: var(--ledger-sans);
  font-size: 15px;
  line-height: 1.55;
  letter-spacing: 0;
}

/* NOTE (redesign Slice D, decision-log 2026-07-14): the .rpt-sim SIMULATED banner
   and its CSS were removed with the honesty freeze-reversal — the public report/demo
   pages are disclaimer-free. Print-color-adjust: exact is still carried by the
   verdict flag (.rpt-verdict-flag) and the severity marks (.rpt-sev::before), which
   legitimately print colour on ink/tinted grounds. */

/* ---- masthead — flush-left, closed by the single 4px burgundy accent rule ---- */
.rpt-head {
  margin-top: 0;
  padding: 44px 0 30px;
  border-bottom: 4px solid var(--um);
}
.rpt-eyebrow {
  margin: 0;
  font-family: var(--ledger-sans);
  font-size: 11px;
  font-weight: 700;
  letter-spacing: 0.18em;
  text-transform: uppercase;
  color: var(--graphite);
}
.rpt-title {
  margin: 16px 0 0;
  /* S3: masthead adopts the site serif per the mockup's report register. */
  font-family: var(--serif);
  font-size: clamp(34px, 4.4vw, 52px);
  font-weight: 600;
  letter-spacing: -0.012em;
  line-height: 1.05;
  color: var(--ink);
  max-width: 24ch;
  text-wrap: balance;
}
.rpt-intro {
  margin: 22px 0 0;
  font-size: 15.5px;
  line-height: 1.6;
  color: var(--body);
  max-width: 68ch;
}

/* ---- surface toggle — a flush mono tab strip on a hairline; ink underline for
   the active surface (the burgundy accent is reserved for its three sanctioned roles) -- */
.rpt-toolbar {
  display: flex;
  gap: 0;
  margin-top: 28px;
  border-bottom: 1px solid var(--hairline);
}
.rpt-tab {
  font: inherit;
  font-family: var(--ledger-mono);
  font-size: 12px;
  letter-spacing: 0.04em;
  cursor: pointer;
  padding: 10px 16px 11px;
  border: none;
  border-bottom: 2px solid transparent;
  border-radius: 0;
  background: none;
  color: var(--graphite);
  margin-bottom: -1px;
  transition:
    color 0.15s ease,
    border-color 0.15s ease;
}
.rpt-tab:first-child {
  padding-left: 0;
}
.rpt-tab:hover {
  color: var(--ink);
}
.rpt-tab.active {
  color: var(--ink);
  border-bottom-color: var(--ink);
}

/* ---- the modular-grid armature: 184px caption rail | continuous hairline | body */
.rpt-sec {
  display: grid;
  grid-template-columns: 184px minmax(0, 1fr);
  border-top: 1px solid var(--hairline);
}
.rpt-toolbar + .rpt-sec {
  border-top: none;
}
.rpt-rail {
  margin: 0;
  padding: 30px 20px 30px 0;
  font-family: var(--ledger-sans);
  font-size: 11px;
  font-weight: 700;
  letter-spacing: 0.18em;
  text-transform: uppercase;
  color: var(--graphite);
}
.rpt-bodycol {
  min-width: 0;
  border-left: 1px solid var(--hairline);
  padding: 30px 0 34px 40px;
}

/* ---- verdict — the flag is a solid ink stamp (paper-white text on ink, per the
   --paper token note); the count is mono; the frozen tally sits on its own ruled
   row as a single mono line (it is one text node — never split into squares) ---- */
.rpt-verdict {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  column-gap: 22px;
  row-gap: 0;
  margin: 0;
  padding: 0;
  border: none;
  border-radius: 0;
  background: none;
}
.rpt-verdict-flag {
  font-family: var(--ledger-sans);
  font-size: 30px;
  font-weight: 800;
  letter-spacing: -0.02em;
  line-height: 1;
  color: var(--paper);
  background: var(--ink);
  padding: 11px 18px;
  -webkit-print-color-adjust: exact;
  print-color-adjust: exact;
}
.rpt-verdict-count {
  font-family: var(--ledger-mono);
  font-variant-numeric: tabular-nums;
  font-size: 16px;
  font-weight: 700;
  color: var(--ink);
}
.rpt-verdict-tally {
  width: 100%;
  margin: 20px 0 0;
  padding-top: 14px;
  border-top: 1px solid var(--hairline);
  font-family: var(--ledger-mono);
  font-variant-numeric: tabular-nums;
  font-size: 12.5px;
  color: var(--graphite);
}

/* ---- meta ledger ---- */
.rpt-meta {
  margin: 0;
  border: none;
  border-radius: 0;
  overflow: visible;
}
.rpt-mrow {
  display: grid;
  grid-template-columns: 170px minmax(0, 1fr);
  gap: 24px;
  padding: 12px 0;
  border-top: 1px solid var(--hairline);

