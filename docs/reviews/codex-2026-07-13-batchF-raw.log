   225	
   226	  const CONTRACT: ReadonlyArray<[name: string, pattern: RegExp]> = [
   227	    ["prototype/simulated status", /Demo \/ portfolio prototype — simulated data throughout/],
   228	    ["replay provenance", /static replay of committed,? labeled fixtures/],
   229	    ["recorded-fixture provenance", /recorded static fixture/],
