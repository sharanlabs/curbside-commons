    85	    function walk(file: string) {
    86	      if (seen.has(file)) return;
    87	      seen.add(file);
    88	      if (file.endsWith(".json")) return;
    89	      const src = readFileSync(file, "utf8");
    90	      for (const m of src.matchAll(IMPORT_RE)) {
    91	        const spec = m[1] ?? m[2];
