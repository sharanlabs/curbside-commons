    68	describe("playground browser safety (import-graph walk)", () => {
    69	  it("the seam's transitive import closure reaches no node:* module", () => {
    70	    const seen = new Set<string>();
    71	    const offenders: string[] = [];
    72	    const IMPORT_RE = /(?:import|export)[^"']*from\s+["']([^"']+)["']|import\s+["']([^"']+)["']/g;
    73	
    74	    function resolveSpec(fromFile: string, spec: string): string | null {
    75	      let base: string;
    76	      if (spec.startsWith("@/")) base = join(root, spec.slice(2));
    77	      else if (spec.startsWith(".")) base = resolve(dirname(fromFile), spec);
    78	      else return null; // bare specifier — handled by the caller
    79	      for (const cand of [base, `${base}.ts`, `${base}.tsx`, `${base}.json`, join(base, "index.ts")]) {
    80	        if (existsSync(cand)) return cand;
    81	      }
    82	      return null;
    83	    }
