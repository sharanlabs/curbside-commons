   211	  const normalizeJsx = (s: string) =>
   212	    s
   213	      .replace(/\{\/\*[\s\S]*?\*\/\}/g, " ")
   214	      .replace(/<[^>]+>/g, " ")
   215	      .replace(/\{["'` ]*\}/g, " ")
   216	      .replace(/&ldquo;|&rdquo;/g, '"')
   217	      .replace(/&rsquo;/g, "'")
   218	      .replace(/\s+/g, " ");
