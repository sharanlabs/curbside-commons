    42	        <span className="lp-catch-src">the committed demo report — synthetic restaurant</span>
    43	      </div>
    44	      <div className="lp-catch-verdict">
    45	        <span className="lp-catch-fail">{expectedAcpReport.ok ? "PASS" : "FAIL"}</span>
    46	        <span className="lp-catch-tally">
    47	          {TALLY.total} findings · {TALLY.errors} error / {TALLY.warns} warn
    48	        </span>
    49	      </div>
    50	      {[CATCH_A, CATCH_B].map((f) => (
    51	        <div className="lp-catch-row" key={f.claim.id}>
    52	          <p className="lp-catch-plain">{f.plainLine}</p>
    53	          <p className="lp-catch-receipt">
    54	            <span className="ds-mono">{f.claim.id}</span> · rule{" "}
    55	            <span className="ds-mono">{f.ruleId}</span> · source{" "}
    56	            <span className="ds-mono">{f.claim.source}</span>
    57	          </p>
    58	        </div>
    59	      ))}
    60	      <p className="lp-catch-foot">
    61	        Every line above is deterministic — the same input always produces this same report, with no
    62	        AI calls in the verifier.
    63	      </p>
    64	    </div>
    65	  );
