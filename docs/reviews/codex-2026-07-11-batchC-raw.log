    39	const width = Math.ceil(maxCols * CHAR_W + PAD_X * 2);
    40	const height = PAD_TOP + lines.length * LINE_H + PAD_BOTTOM;
    41	
    42	// ---- 3. Beat grouping for the sequential reveal -----------------------------
    43	// A new "beat block" starts at each `----`/`====` separator line; the reveal
    44	// staggers block by block so the story reads top-down like the live terminal.
    45	const isRule = (l: string) => /^[=-]{20,}$/.test(l.trim());
    46	let block = 0;
    47	const blockOf: number[] = lines.map((l, i) => {
    48	  if (i > 0 && isRule(l) && !isRule(lines[i - 1] ?? "")) block += 1;
    49	  return block;
    50	});
    51	const blockCount = block + 1;
    52	const STEP_S = 0.55; // delay between blocks
    53	const FADE_S = 0.5;
