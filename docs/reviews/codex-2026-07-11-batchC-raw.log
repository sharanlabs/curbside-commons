    21	      .withTags(["wcag2a", "wcag2aa", "wcag21a", "wcag21aa"])
    22	      .analyze();
    23	    const summary = results.violations.map((v) => ({
    24	      id: v.id,
    25	      impact: v.impact,
    26	      nodes: v.nodes.length,
    27	      help: v.help,
    28	    }));
    29	    expect(summary, JSON.stringify(summary, null, 2)).toEqual([]);
    30	  });
    31	}

