     1	/**
     2	 * Artifact-mode static server (plan v3.3 S5 → consumed by the RELEASE GATE).
     3	 *
     4	 * Serves a RECORDED `out/` export exactly the way a static host (Cloudflare
     5	 * Pages) maps clean URLs — /eval → out/eval.html, / → out/index.html,
     6	 * /legacy/merchant/M001 → out/legacy/merchant/M001.html — with NO dev server,
     7	 * NO build step, and zero dependencies (node builtins only). The release gate's
     8	 * e2e contracts run against this so they exercise the immutable artifact, not
     9	 * a rebuild.
    10	 *
    11	 * Usage: node scripts-ts/serve-artifact.mts [port] [dir]   (defaults 3200, out/)
    12	 */
    13	import { createServer } from "node:http";
    14	import { readFile } from "node:fs/promises";
    15	import { existsSync } from "node:fs";
    16	import { extname, join, normalize, resolve } from "node:path";
    17	
    18	const PORT = Number(process.argv[2] ?? 3200);
    19	const ROOT = resolve(process.argv[3] ?? "out");
    20	
    21	const MIME: Record<string, string> = {
    22	  ".html": "text/html; charset=utf-8",
    23	  ".css": "text/css; charset=utf-8",
    24	  ".js": "text/javascript; charset=utf-8",
    25	  ".json": "application/json",
    26	  ".txt": "text/plain; charset=utf-8",
    27	  ".svg": "image/svg+xml",
    28	  ".ico": "image/x-icon",
    29	  ".woff2": "font/woff2",
    30	};
    31	
    32	function candidates(urlPath: string): string[] {
    33	  // Normalize + confine to ROOT (no traversal).
    34	  const clean = normalize(urlPath).replace(/^(\.\.[/\\])+/, "").replace(/\/+$/, "");
    35	  const p = clean === "" || clean === "/" ? "/index" : clean;
    36	  return [join(ROOT, p), join(ROOT, `${p}.html`), join(ROOT, p, "index.html")];
    37	}
    38	
    39	const server = createServer(async (req, res) => {
    40	  const urlPath = decodeURIComponent((req.url ?? "/").split("?")[0]);
    41	  for (const file of candidates(urlPath)) {
    42	    if (!file.startsWith(ROOT)) break; // traversal guard
    43	    if (existsSync(file) && extname(file) !== "") {
    44	      const body = await readFile(file);
    45	      res.writeHead(200, { "content-type": MIME[extname(file)] ?? "application/octet-stream" });
    46	      res.end(body);
    47	      return;
    48	    }
    49	  }
    50	  const notFound = join(ROOT, "404.html");
    51	  res.writeHead(404, { "content-type": "text/html; charset=utf-8" });
    52	  res.end(existsSync(notFound) ? await readFile(notFound) : "404");
    53	});
    54	
    55	server.listen(PORT, () => {
    56	  console.log(`artifact-mode static server: ${ROOT} on http://localhost:${PORT}`);
    57	});
     1	import { defineConfig, devices } from "@playwright/test";
     2	
     3	/**
     4	 * ARTIFACT-MODE e2e config (plan v3.3 S5; the RELEASE GATE runs both contracts
     5	 * under this): statically serves a RECORDED `out/` export via
     6	 * scripts-ts/serve-artifact.mts — NO `next dev`, NO build. The same specs in
     7	 * evals/e2e/ run under both this and the dev config (playwright.config.ts);
     8	 * a contract that only passes in dev mode is a defect.
     9	 *
    10	 * Run: npm run test:e2e:artifact  (requires an existing out/ — it will NOT build one)
    11	 */
    12	export default defineConfig({
    13	  testDir: "./evals/e2e",
    14	  testMatch: "**/*.spec.ts",
    15	  fullyParallel: true,
    16	  forbidOnly: !!process.env.CI,
    17	  retries: 0,
    18	  reporter: process.env.CI ? "github" : "list",
    19	  use: {
    20	    baseURL: "http://localhost:3200",
    21	    trace: "off",
    22	  },
    23	  projects: [{ name: "chromium-artifact", use: { ...devices["Desktop Chrome"] } }],
    24	  webServer: {
    25	    command: "node scripts-ts/serve-artifact.mts 3200 out",
    26	    url: "http://localhost:3200",
    27	    reuseExistingServer: !process.env.CI,
    28	    timeout: 30_000,
    29	  },
    30	});
     1	# CI (plan v3.3 S3a — NEW-03): the committed gates, run on every push/PR.
     2	# Hardening per plan §Gates: Node 24 pinned (repo engines >=24; native type-stripping),
     3	# immutable action pins (full commit SHAs, resolved live from the upstream repos
     4	# 2026-07-10), least permissions, per-ref concurrency, explicit timeout.
     5	# NO claim edits ride this slice — the README's CI wording flips at S3b, strictly
     6	# after this workflow's first green run is observed (plan order).
     7	# e2e joined at S5 (per plan): BOTH contracts (canonical + legacy why-chain) run in
     8	# ARTIFACT MODE against the exact out/ that `npm run verify` just built — the same
     9	# static-serving path the release gate and the host use. Dev-mode e2e stays a local
    10	# + release-gate check (the release gate runs both modes).
    11	name: CI
    12	
    13	# Batch-A Codex P2 (accepted-fixed): unqualified push trigger per the plan's
    14	# "on push/PR" — no branch filter; per-ref concurrency below de-duplicates.
    15	on:
    16	  push:
    17	  pull_request:
    18	
