+  <script>
+  (function () {
+    "use strict";
+    var reduceMq = window.matchMedia("(prefers-reduced-motion: reduce)");
+
+    /* --------------------------- hold-to-verify --------------------------- */
+    var zone = document.getElementById("hold-zone");
+    var btn = document.getElementById("hold-btn");
+    var revealPlain = document.getElementById("reveal-plain");
+    var details = document.getElementById("verdict-fallback");
+    var card = document.getElementById("verdict-card");
+    var status = document.getElementById("hold-status");
+    var HOLD_MS = 1400;
+    var timer = null;
+    var holding = false;
+    var revealed = false;
+
+    function setStatus(msg) { if (status) { status.textContent = msg; } }
+
+    function reveal() {
+      if (revealed) { return; }
+      revealed = true;
+      holding = false;
+      if (timer) { clearTimeout(timer); timer = null; }
+      zone.classList.remove("holding");
+      zone.classList.add("done");
+      btn.setAttribute("aria-expanded", "true");
+      details.open = true;
+      // 320ms ease-out entrance (opacity-only under reduced motion, via CSS)
+      requestAnimationFrame(function () { card.classList.add("revealed"); });
+      setStatus("Verified against the record. FAIL — 16 findings (11 error, 5 warn). Verdict shown below.");
+    }
+
+    function startHold() {
+      if (revealed || holding) { return; }
+      // reduced motion: instant state change, no timed fill
+      if (reduceMq.matches) { reveal(); return; }
+      holding = true;
+      zone.classList.add("holding");
+      setStatus("Verifying — hold to weigh the serving copy against the record.");
+      timer = setTimeout(reveal, HOLD_MS);
+    }
+
+    function cancelHold() {
+      if (!holding) { return; }
+      holding = false;
+      if (timer) { clearTimeout(timer); timer = null; }
+      zone.classList.remove("holding");
+      setStatus("Released early — the check did not complete. Hold again, or reveal without holding.");
+    }
+
+    // pointer: capture so move/up/cancel resolve to this button
+    btn.addEventListener("pointerdown", function (e) {
+      if (typeof e.button === "number" && e.button !== 0) { return; }
+      try { btn.setPointerCapture(e.pointerId); } catch (err) {}
+      e.preventDefault();
+      startHold();
+    });
+    btn.addEventListener("pointerup", function (e) {
+      try { btn.releasePointerCapture(e.pointerId); } catch (err) {}
+      cancelHold();
+    });
+    btn.addEventListener("pointercancel", cancelHold);
+    btn.addEventListener("pointerleave", cancelHold);
+
+    // keyboard: Space / Enter — keydown starts, keyup releases, key-repeat guarded
+    function isActivateKey(e) {
+      return e.key === " " || e.key === "Spacebar" || e.code === "Space" || e.key === "Enter";
+    }
+    btn.addEventListener("keydown", function (e) {
+      if (!isActivateKey(e)) { return; }
+      e.preventDefault();            // stop scroll + the native click-activation
+      if (e.repeat) { return; }      // guard auto-repeat
+      startHold();
+    });
+    btn.addEventListener("keyup", function (e) {
+      if (!isActivateKey(e)) { return; }
+      e.preventDefault();
+      cancelHold();
+    });
+    // losing focus mid-hold counts as release
+    btn.addEventListener("blur", cancelHold);
+
+    // no-hold path — completes the same reveal instantly
+    revealPlain.addEventListener("click", function () { reveal(); });
+
+    // JS present: start closed (hold / reveal buttons drive the disclosure;
+    // the native <summary> is hidden via the .js CSS rule).
+    details.open = false;
+
+    /* ---------------------- station reveal on scroll ---------------------- */
+    var reveals = Array.prototype.slice.call(document.querySelectorAll(".reveal"));
+    if ("IntersectionObserver" in window && !reduceMq.matches) {
+      var io = new IntersectionObserver(function (entries) {
+        entries.forEach(function (entry) {
+          if (!entry.isIntersecting) { return; }
+          var el = entry.target;
+          var delay = parseInt(el.getAttribute("data-stagger") || "0", 10) || 0;
+          setTimeout(function () { el.classList.add("in"); }, delay);
+          io.unobserve(el);
+        });
+      }, { threshold: 0.12, rootMargin: "0px 0px -6% 0px" });
+      reveals.forEach(function (el) { io.observe(el); });
+    } else {
+      // no IO or reduced motion: show everything immediately
+      reveals.forEach(function (el) { el.classList.add("in"); });
+    }
+  })();
+  </script>
+</body>
+</html>

