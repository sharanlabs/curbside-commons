     3	/**
     4	 * The landing's shown catch (S5 retell) — a condensed excerpt of the SAME
     5	 * committed golden report the /report page renders in full. Nothing here is
     6	 * authored: the verdict, tally, and both findings are imported from the golden
     7	 * and selected by rule id (if the golden ever changes shape, the build fails
     8	 * loudly rather than showing a stale story). Server component; settled in SSR.
     9	 */
    10	
    11	type Finding = {
    12	  claim: { id: string; source: string; field: string; value: unknown };
    13	  ruleId: string;
    14	  severity: string;
    15	  plainLine: string;
    16	};
    17	
    18	const findings = expectedAcpReport.findings as Finding[];
    19	
    20	function mustFind(ruleId: string, field: string): Finding {
    21	  const f = findings.find((x) => x.ruleId === ruleId && x.claim.field === field);
    22	  if (!f) throw new Error(`TruthCatch: golden report finding missing: ${ruleId}/${field}`);
    23	  return f;
    24	}
    25	
    26	// The two most legible catches in the golden: a sold-out item served as in
    27	// stock, and an item hidden in the merchant's own catalog but still served.
    28	const CATCH_A = mustFind("LST-AVAIL-STATE", "availability");
    29	const CATCH_B = mustFind("LST-AVAIL-HIDDEN-SHOWN", "existence");
    30	
    31	const TALLY = {
    32	  total: findings.length,
    33	  errors: findings.filter((f) => f.severity === "error").length,
    34	  warns: findings.filter((f) => f.severity === "warn").length,
    35	};
    36	
    37	export function TruthCatch() {
    38	  return (
    39	    <div className="lp-catch" role="figure" aria-label="Two findings from the committed demo verifier report">
