+<!DOCTYPE html>
+<html lang="en" data-scroll-behavior="smooth">
+<head>
+<meta charset="utf-8" />
+<meta name="viewport" content="width=device-width, initial-scale=1" />
+<title>Meridian — Curbside Commons design sample (simulated prototype)</title>
+<meta name="robots" content="noindex" />
+<meta name="description" content="Design-lane sample (S6b, 2026-07-11) for Curbside Commons — the deterministic commerce-truth verifier. Simulated prototype; zero external requests; not a live service." />
+<script>
+  /* Add the js hook synchronously (before paint) so progressively-enhanced
+     controls and the reveal pre-states apply from first render. No-JS never
+     gets this class, so all content stays visible without JavaScript. */
+  document.documentElement.className += " js";
+</script>
+<style>
+  /* =========================================================================
+     Meridian — S6b design sample (brief: docs/design-brief-s6b-2026-07-11.md).
+     Pure-white ground (owner word for this sample), warm near-black ink, ONE
+     wine/oxblood accent (continuity with the shipped Oxblood identity). Every
+     text/ground pair recomputed >= 4.5:1 on #FFFFFF. Severity = shape + word,
+     never colour alone. Zero external requests: system fonts, inline SVG.
+     ========================================================================= */
+
+  :root {
+    --ground: #ffffff;
+    --panel: #fcfbfc;            /* barely-there wine-neutral panel */
+    --ink: #1a1712;              /* headings / hard marks — 18.1:1 on #fff */
+    --ink-2: #2e2825;            /* strong text — 14.7:1 */
+    --body: #423b38;            /* body — 11.1:1 */
+    --muted: #5c534d;           /* labels / mono — 7.6:1 */
+    --faint: #6d635b;           /* least-essential >=13px — 5.9:1 */
+    --wine: #8a2233;            /* the single accent — 8.9:1 on #fff */
+    --wine-deep: #6e1423;       /* hover / pressed — 11.4:1 */
+    --wine-900: #3e0a13;
+    --wine-soft: rgba(138, 34, 51, 0.055);
+    --wine-line: rgba(138, 34, 51, 0.22);
+    --rule: rgba(62, 10, 19, 0.12);
+    --rule-2: rgba(62, 10, 19, 0.2);
+    --error-ink: #b71f13;       /* severity ink (paired with a shape + word) — 6.5:1 */
+    --warn-ink: #9c3d06;        /* — 6.8:1 */
+
+    --serif: "Iowan Old Style", "Palatino Linotype", Palatino, Georgia, "Times New Roman", serif;
+    --sans: system-ui, -apple-system, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
+    --mono: ui-monospace, "SF Mono", "Menlo", Consolas, "Liberation Mono", monospace;
+
+    --ease-out: cubic-bezier(0.23, 1, 0.32, 1);
+    --ease-inout: cubic-bezier(0.77, 0, 0.175, 1);
+
+    --rail: 88px;
+    --pad: 22px;
+    --spine-x: calc(var(--pad) + (var(--rail) / 2));
+    --maxw: 940px;
+  }
+
+  * { box-sizing: border-box; }
+
+  html { scroll-behavior: smooth; }
+
+  body {
+    margin: 0;
+    background: var(--ground);
+    color: var(--body);
+    font-family: var(--sans);
+    font-size: 17px;
+    line-height: 1.62;
+    -webkit-font-smoothing: antialiased;
+    -moz-osx-font-smoothing: grayscale;
+    text-rendering: optimizeLegibility;
+  }
+
+  ::selection { background: var(--wine-soft); }
+
+  a { color: var(--wine); text-underline-offset: 3px; text-decoration-thickness: 1px; }
+  a:hover { color: var(--wine-deep); }
+
+  .vh {
+    position: absolute; width: 1px; height: 1px; padding: 0; margin: -1px;
+    overflow: hidden; clip: rect(0 0 0 0); white-space: nowrap; border: 0;
+  }
+
+  /* skip link — first in tab order */
+  .skip {
+    position: absolute; left: 12px; top: -48px; z-index: 50;
+    background: var(--ink); color: #fff; padding: 10px 16px; border-radius: 6px;
+    font-weight: 600; text-decoration: none; transition: top 140ms var(--ease-out);
+  }
+  .skip:focus { top: 12px; color: #fff; }
+
+  :focus-visible {
+    outline: 3px solid var(--wine);
+    outline-offset: 3px;
+    border-radius: 3px;
+  }
+
+  /* ---- icon system (extends the committed 20x20 monoline currentColor set) ---- */
+  .ic {
+    width: 20px; height: 20px; flex: 0 0 auto;
+    fill: none; stroke: currentColor; stroke-width: 1.5;
+    stroke-linecap: round; stroke-linejoin: round;
+  }
+
+  /* ================================ NAV ================================= */
+  .topbar {
+    position: sticky; top: 0; z-index: 20;
+    background: rgba(255, 255, 255, 0.86);
+    -webkit-backdrop-filter: saturate(1.1) blur(8px);
+    backdrop-filter: saturate(1.1) blur(8px);
+    border-bottom: 1px solid var(--rule);
+  }
+  .topbar-in {
+    max-width: var(--maxw); margin: 0 auto; padding: 12px var(--pad);
+    display: flex; align-items: center; gap: 20px; flex-wrap: wrap;
+  }
+  .brand {
+    font-family: var(--serif); font-size: 19px; font-weight: 600; letter-spacing: -0.01em;
+    color: var(--ink); text-decoration: none; display: inline-flex; align-items: center; gap: 9px;
+  }
+  .brand .ic { width: 18px; height: 18px; color: var(--wine); }
+  .brand .brand-sub {
+    font-family: var(--sans); font-size: 11px; font-weight: 600; letter-spacing: 0.09em;
+    text-transform: uppercase; color: var(--muted);
+  }
+  .nav { margin-left: auto; display: flex; gap: 4px; flex-wrap: wrap; }
+  .nav a {
+    color: var(--ink-2); text-decoration: none; font-size: 13.5px; font-weight: 500;
+    padding: 6px 10px; border-radius: 7px; transition: background 140ms var(--ease-out), color 140ms var(--ease-out);
+  }
+  @media (hover: hover) and (pointer: fine) {
+    .nav a:hover { background: var(--wine-soft); color: var(--wine-deep); }
+  }
+
+  /* ============================= MERIDIAN =============================== */
+  .meridian-main {
+    position: relative;
+    max-width: var(--maxw); margin: 0 auto; padding: 0 var(--pad);
+  }
+  /* the plumb line — a faint full-height track + a wine fill that extends on scroll */
+  .spine-track, .spine-fill {
+    position: absolute; left: var(--spine-x); top: 0; width: 2px; height: 100%;
+    pointer-events: none;
+  }
+  .spine-track { background: var(--rule-2); }
+  .spine-fill { background: var(--wine); transform-origin: top center; transform: scaleY(1); }
+  @supports (animation-timeline: scroll()) {
+    @media (prefers-reduced-motion: no-preference) {
+      .spine-fill {
+        transform: scaleY(0);
+        animation: spinegrow linear both;
+        animation-timeline: scroll(root block);
+        animation-range: 0% 100%;
+      }
+    }
+  }
+  @keyframes spinegrow { from { transform: scaleY(0); } to { transform: scaleY(1); } }
+
+  .station {
+    position: relative;
+    display: grid; grid-template-columns: var(--rail) minmax(0, 1fr);
+    padding: 52px 0;
+    border-top: 1px solid var(--rule);
+  }
+  .station:first-of-type { border-top: 0; }
+
+  /* the station node — a white-filled ring on the line, carrying the section icon */
+  .node {
+    grid-column: 1; justify-self: center; align-self: start;
+    width: 46px; height: 46px; border-radius: 50%;
+    background: var(--ground); border: 2px solid var(--wine-line);
+    display: flex; align-items: center; justify-content: center;
+    color: var(--wine); position: relative; z-index: 2; margin-top: 2px;
+  }
+  .node .ic { width: 22px; height: 22px; }
+
+  .content { grid-column: 2; padding-left: 8px; }
+  .content > * + * { margin-top: 18px; }
+
+  .eyebrow {
+    display: inline-flex; align-items: center; gap: 8px; margin: 0;
+    font-size: 12px; font-weight: 700; letter-spacing: 0.1em; text-transform: uppercase;
+    color: var(--wine);
+  }
+  .eyebrow .ic { width: 16px; height: 16px; }
+
+  h2.h2 {
+    font-family: var(--serif); color: var(--ink);
+    font-size: clamp(26px, 4.4vw, 38px); line-height: 1.12; letter-spacing: -0.015em;
+    font-weight: 600; margin: 10px 0 0; max-width: 20ch;
+  }
+  h3.h3 {
+    font-family: var(--serif); color: var(--ink-2);
+    font-size: 20px; line-height: 1.2; letter-spacing: -0.01em; font-weight: 600; margin: 0;
+  }
+  .prose { color: var(--body); max-width: 68ch; margin: 0; }
+  .prose em { font-style: italic; color: var(--ink-2); }
+  .kicker {
+    font-family: var(--mono); font-size: 11.5px; letter-spacing: 0.06em; text-transform: uppercase;
+    color: var(--muted); margin: 0;
+  }
+
+  /* ============================== HERO ================================= */
+  #top { padding-top: 40px; }
+  #top .content { padding-left: 8px; }
+  .hero-seal-wrap { display: flex; }
+  .seal {
+    width: clamp(118px, 17vw, 166px); height: auto; color: var(--wine);
+    overflow: visible;
+  }
+  .seal .draw { fill: none; stroke-linecap: round; stroke-linejoin: round; }
+  .seal .seal-ring { stroke: var(--wine); stroke-width: 2; }
+  .seal .seal-shield { stroke: var(--ink); stroke-width: 2; }
+  .seal .seal-check { stroke: var(--wine); stroke-width: 2.6; }
+  .seal .ringtext {
+    font-family: var(--sans); font-size: 6.4px; font-weight: 600; letter-spacing: 1.6px;
+    fill: var(--wine);
+  }
+  h1.hero-h1 {
+    font-family: var(--serif); color: var(--ink);
+    font-size: clamp(34px, 6.2vw, 60px); line-height: 1.06; letter-spacing: -0.02em;
+    font-weight: 600; margin: 26px 0 0; max-width: 17ch;
+  }
+  h1 .mark {
+    color: var(--wine); font-style: italic;
+    box-shadow: inset 0 -0.14em 0 var(--wine-soft);
+  }
+  .hero-lede {
+    font-size: clamp(17px, 2.2vw, 20px); color: var(--body); max-width: 60ch; margin: 22px 0 0;
+    line-height: 1.55;
+  }
+  .hero-cta { display: flex; gap: 12px; flex-wrap: wrap; margin-top: 28px; }
+
+  .btn {
+    display: inline-flex; align-items: center; gap: 8px;
+    font: inherit; font-size: 15px; font-weight: 600; cursor: pointer;
+    padding: 12px 20px; border-radius: 999px; text-decoration: none;
+    transition: transform 160ms var(--ease-out), background 160ms var(--ease-out),
+                color 160ms var(--ease-out), border-color 160ms var(--ease-out);
+  }
+  .btn .ic { width: 17px; height: 17px; }
+  .btn.primary { background: var(--wine); color: #fff; border: 2px solid var(--wine); }
+  .btn.ghost { background: transparent; color: var(--ink); border: 2px solid var(--rule-2); }
+  @media (hover: hover) and (pointer: fine) {
+    .btn.primary:hover { background: var(--wine-deep); border-color: var(--wine-deep); }
+    .btn.ghost:hover { border-color: var(--wine); color: var(--wine-deep); }
+  }
+  .btn:active { transform: scale(0.97); }
+
+  /* =========================== THE CATCH =============================== */
+  .sim {
+    display: flex; gap: 12px; align-items: flex-start;
+    border: 1px solid var(--wine-line); background: var(--wine-soft);
+    border-left: 4px solid var(--wine); border-radius: 8px;
+    padding: 14px 16px; margin-top: 26px;
+  }
+  .sim-tag {
+    flex: 0 0 auto; font-family: var(--mono); font-size: 11px; font-weight: 700;
+    letter-spacing: 0.12em; color: #fff; background: var(--wine);
+    padding: 3px 8px; border-radius: 4px; margin-top: 2px;
+  }
+  .sim-text { font-size: 13.5px; line-height: 1.5; color: var(--ink-2); }
+
+  .hold-zone { margin-top: 30px; }
+  .hold-instr { font-size: 14.5px; color: var(--body); max-width: 60ch; margin: 0 0 16px; }
+  .hold-controls { display: flex; gap: 14px; flex-wrap: wrap; align-items: center; }
+
+  /* Hold-to-verify button — resting: wine text on white with a wine border.
+     The rising fill is solid wine carrying a WHITE copy of the label, so the
+     label reads wine-on-white where unfilled and white-on-wine where filled:
+     both pairs clear 4.5:1 across the whole fill sweep. */
+  .hold-btn {
+    position: relative; overflow: hidden; isolation: isolate;
+    font: inherit; font-size: 15px; font-weight: 700; letter-spacing: 0.01em;
+    cursor: pointer; -webkit-user-select: none; user-select: none; touch-action: none;
+    padding: 14px 30px; min-width: 220px; text-align: center;
+    background: var(--ground); color: var(--wine);
+    border: 2px solid var(--wine); border-radius: 999px;
+    transition: transform 160ms var(--ease-out);
+  }
+  .hold-btn .hold-base { position: relative; z-index: 1; }
+  .hold-fill {
