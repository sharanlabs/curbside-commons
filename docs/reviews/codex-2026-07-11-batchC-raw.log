+
+  .reveal-plain {
+    font: inherit; font-size: 14px; font-weight: 600; cursor: pointer;
+    background: transparent; color: var(--ink); border: 0;
+    padding: 10px 6px; border-bottom: 2px solid var(--rule-2); border-radius: 2px;
+    transition: color 140ms var(--ease-out), border-color 140ms var(--ease-out), transform 160ms var(--ease-out);
+  }
