    58	const classFor = (l: string): string => {
    59	  if (/\[ERROR\]/.test(l)) return "err";
    60	  if (/\[FLAG\]/.test(l)) return "flag";
    61	  if (/\[OK\]/.test(l)) return "ok";
    62	  if (/^BEAT \d/.test(l.trim())) return "beat";
    63	  if (isRule(l)) return "rule";
    64	  if (/^\s*▸/.test(l)) return "note";
    65	  if (/^(claim|reference|rule|class):|^\s+(claim|reference|rule|class):/.test(l.trim())) return "receipt";
    66	  return "body";
    67	};
    68	const text = lines
    69	  .map((l, i) => {
