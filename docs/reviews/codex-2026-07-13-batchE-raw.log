   951	      reveals.forEach(function (el) { io.observe(el); });
   952	    } else {
   953	      reveals.forEach(function (el) { el.classList.add("in"); });  // no IO / reduced motion: show all
   954	    }
   955	
   956	    /* ------------------- section index scroll-spy (state) ----------------- */
   957	    var idxLinks = {};
   958	    Array.prototype.slice.call(document.querySelectorAll(".idx a")).forEach(function (a) {
   959	      var href = a.getAttribute("href") || "";
   960	      if (href.charAt(0) === "#") { idxLinks[href.slice(1)] = a; }
   961	    });
   962	    var sections = Array.prototype.slice.call(document.querySelectorAll(".story section[id], .story[id]"));
   963	    if ("IntersectionObserver" in window) {
   964	      var current = "top";
   965	      var setActive = function (id) {
   966	        if (id === current) { return; }
