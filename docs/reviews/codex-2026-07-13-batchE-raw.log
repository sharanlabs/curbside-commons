   826	  <script>
   827	  (function () {
   828	    "use strict";
   829	    var reduceMq = window.matchMedia("(prefers-reduced-motion: reduce)");
   830	
   831	    /* --------------------------- hold-to-verify --------------------------- */
   832	    var zone = document.getElementById("hold-zone");
   833	    var btn = document.getElementById("hold-btn");
   834	    var revealPlain = document.getElementById("reveal-plain");
   835	    var details = document.getElementById("verdict-fallback");
   836	    var card = document.getElementById("verdict-card");
   837	    var status = document.getElementById("hold-status");
   838	    var HOLD_MS = 1400;
   839	    var timer = null;
   840	    var holding = false;
   841	    var revealed = false;
   842	
   843	    function setStatus(msg) { if (status) { status.textContent = msg; } }
   844	
   845	    function reveal() {
   846	      if (revealed) { return; }
   847	      revealed = true;
   848	      holding = false;
   849	      if (timer) { clearTimeout(timer); timer = null; }
   850	      zone.classList.remove("holding");
   851	      zone.classList.add("done");
   852	      btn.setAttribute("aria-expanded", "true");
   853	      revealPlain.setAttribute("aria-expanded", "true");
   854	      details.open = true;
   855	      setStatus("Verified against the record. FAIL — 16 findings (11 error, 5 warn). Verdict shown below.");
   856	    }
   857	
   858	    function startHold() {
   859	      if (revealed || holding) { return; }
   860	      if (reduceMq.matches) { reveal(); return; }   // reduced motion: instant, no timed fill
   861	      holding = true;
   862	      zone.classList.add("holding");
   863	      setStatus("Verifying — hold to weigh the serving copy against the record.");
   864	      timer = setTimeout(reveal, HOLD_MS);
   865	    }
   866	
   867	    function cancelHold() {
   868	      if (!holding) { return; }
   869	      holding = false;
   870	      if (timer) { clearTimeout(timer); timer = null; }
   871	      zone.classList.remove("holding");
   872	      setStatus("Released early — the check did not complete. Hold again, or reveal without holding.");
   873	    }
   874	
   875	    if (btn && revealPlain && details && card) {
   876	      // pointer: capture so move/up/cancel resolve to this button
   877	      btn.addEventListener("pointerdown", function (e) {
   878	        if (typeof e.button === "number" && e.button !== 0) { return; }
   879	        try { btn.setPointerCapture(e.pointerId); } catch (err) {}
   880	        e.preventDefault();
   881	        startHold();
   882	      });
   883	      btn.addEventListener("pointerup", function (e) {
   884	        try { btn.releasePointerCapture(e.pointerId); } catch (err) {}
   885	        cancelHold();
   886	      });
   887	      btn.addEventListener("pointercancel", cancelHold);
   888	      btn.addEventListener("pointerleave", cancelHold);
   889	
   890	      // keyboard: Space / Enter — keydown starts, keyup releases, key-repeat guarded
   891	      function isActivateKey(e) {
   892	        return e.key === " " || e.key === "Spacebar" || e.code === "Space" || e.key === "Enter";
   893	      }
   894	      btn.addEventListener("keydown", function (e) {
   895	        if (!isActivateKey(e)) { return; }
   896	        e.preventDefault();            // stop scroll + native click-activation
   897	        if (e.repeat) { return; }      // guard auto-repeat
   898	        startHold();
   899	      });
   900	      btn.addEventListener("keyup", function (e) {
   901	        if (!isActivateKey(e)) { return; }
   902	        e.preventDefault();
   903	        cancelHold();
   904	      });
   905	      btn.addEventListener("blur", cancelHold);   // losing focus mid-hold = release
   906	
   907	      revealPlain.addEventListener("click", function () { reveal(); });  // no-hold path
   908	
   909	      // JS present: start closed (buttons drive disclosure; native <summary> hidden via CSS)
   910	      details.open = false;
   911	    }
   912	
   913	    /* --------------- seal progress ring: JS scroll fallback --------------- */
   914	    /* CSS scroll-driven animation handles this where supported (no JS). Only
   915	       when unsupported AND motion is allowed do we drive it from scroll. */
   916	    var supportsST = (typeof CSS !== "undefined" && CSS.supports && CSS.supports("animation-timeline: scroll()"));
   917	    if (!reduceMq.matches && !supportsST) {
   918	      var seal = document.getElementById("seal-svg");
   919	      if (seal) {
   920	        seal.classList.add("seal-fallback");
   921	        var docEl = document.documentElement;
   922	        var sealTicking = false;
   923	        var updateSeal = function () {
   924	          sealTicking = false;
   925	          var max = docEl.scrollHeight - docEl.clientHeight;
   926	          var y = window.pageYOffset || docEl.scrollTop || 0;
   927	          var p = max > 0 ? Math.min(1, Math.max(0, y / max)) : 1;
   928	          docEl.style.setProperty("--sp", String(p));
   929	        };
   930	        var onSeal = function () {
   931	          if (!sealTicking) { sealTicking = true; requestAnimationFrame(updateSeal); }
   932	        };
   933	        window.addEventListener("scroll", onSeal, { passive: true });
   934	        window.addEventListener("resize", onSeal, { passive: true });
   935	        updateSeal();
   936	      }
   937	    }
   938	
   939	    /* ---------------------- station reveal on scroll ---------------------- */
   940	    var reveals = Array.prototype.slice.call(document.querySelectorAll(".reveal"));
   941	    if ("IntersectionObserver" in window && !reduceMq.matches) {
   942	      var io = new IntersectionObserver(function (entries) {
   943	        entries.forEach(function (entry) {
