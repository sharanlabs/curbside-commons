   313	
   314	  /* resting: wine text on white with a wine border. The rising fill is solid
   315	     wine carrying a WHITE copy of the label, so the label reads wine-on-white
   316	     where unfilled and white-on-wine where filled — both pairs clear 4.5:1
   317	     across the whole fill sweep. */
   318	  .hold-btn {
   319	    position: relative; overflow: hidden; isolation: isolate;
   320	    font: inherit; font-size: 15px; font-weight: 700; letter-spacing: 0.01em;
   321	    cursor: pointer; -webkit-user-select: none; user-select: none; touch-action: none;
   322	    padding: 14px 30px; min-width: 220px; text-align: center;
   323	    background: var(--ground); color: var(--wine);
   324	    border: 2px solid var(--wine); border-radius: 999px;
   325	  }
