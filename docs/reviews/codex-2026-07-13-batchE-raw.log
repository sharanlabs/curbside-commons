     1	import type { NextConfig } from "next";
     2	import { execSync } from "node:child_process";
     3	
     4	/**
     5	 * Build provenance injection (plan v3.3 E1a; consumed by lib/build-info.ts and
     6	 * rendered in the site footer). Precedence: explicit BUILD_SOURCE_SHA /
     7	 * BUILD_TIMESTAMP_UTC env (the clean-room PRE-GATE build sets these) → live git
     8	 * (with an honest "+dirty" marker) → empty (build-info falls back to the
     9	 * labeled "untracked build" line rather than fabricating provenance).
    10	 */
    11	function resolveBuildProvenance(): { sha: string; timeUtc: string } {
    12	  const timeUtc = process.env.BUILD_TIMESTAMP_UTC ?? new Date().toISOString();
    13	  if (process.env.BUILD_SOURCE_SHA) return { sha: process.env.BUILD_SOURCE_SHA, timeUtc };
    14	  try {
    15	    const sha = execSync("git rev-parse HEAD", { stdio: ["ignore", "pipe", "ignore"] })
    16	      .toString()
    17	      .trim();
    18	    const dirty =
    19	      execSync("git status --porcelain", { stdio: ["ignore", "pipe", "ignore"] })
    20	        .toString()
    21	        .trim().length > 0;
    22	    return { sha: dirty ? `${sha}+dirty` : sha, timeUtc };
    23	  } catch {
    24	    return { sha: "", timeUtc };
    25	  }
    26	}
    27	
    28	const buildProvenance = resolveBuildProvenance();
    29	
    30	const nextConfig: NextConfig = {
    31	  env: {
    32	    NEXT_PUBLIC_BUILD_SHA: buildProvenance.sha,
    33	    NEXT_PUBLIC_BUILD_TIME_UTC: buildProvenance.timeUtc,
    34	  },
    35	  typedRoutes: false,
    36	  allowedDevOrigins: ["127.0.0.1"],
    37	  // Static export for the episodic showcase deploy (docs/plan-deploy.md, owner-worded 2026-07-08).
    38	  // All 30 routes prerender Static/SSG; no server features in app/. out/ is gitignored build
    39	  // output — the legacy oracle artifacts that previously occupied out/ live in
    40	  // legacy/activation/oracle/ (relocated 2026-07-08, byte-identical).
    41	  output: "export",
    42	};
    43	
    44	export default nextConfig;
