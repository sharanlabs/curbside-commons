   634	<p class="site-end">Design-lane sample &mdash; Variation B &ldquo;Gallery Cards&rdquo; (owner iterate word, 2026-07-12). Not served by the live site; a design-process record for owner reaction. Base content: mockups/meridian-2026-07-11.html; brief: docs/design-brief-s6b-2026-07-11.md.</p>
   635	
   636	<script>
   637	(function () {
   638	  "use strict";
   639	  var reduceMq = window.matchMedia("(prefers-reduced-motion: reduce)");
   640	
   641	  /* ------------------------------ mini-nav ------------------------------- */
   642	  var nav = document.getElementById("mininav");
   643	  function onScroll() {
   644	    if (window.scrollY > 8) { nav.classList.add("scrolled"); }
   645	    else { nav.classList.remove("scrolled"); }
   646	  }
   647	  window.addEventListener("scroll", onScroll, { passive: true });
   648	  onScroll();
   649	
   650	  /* --------------------------- hold-to-verify ---------------------------- */
   651	  var zone = document.getElementById("hold-zone");
   652	  var btn = document.getElementById("hold-btn");
   653	  var revealPlain = document.getElementById("reveal-plain");
   654	  var details = document.getElementById("verdict-fallback");
   655	  var card = document.getElementById("verdict-card");
   656	  var status = document.getElementById("hold-status");
   657	  var HOLD_MS = 1400;
   658	  var timer = null;
   659	  var holding = false;
   660	  var revealed = false;
   661	
   662	  function setStatus(msg) { if (status) { status.textContent = msg; } }
   663	
   664	  function reveal() {
   665	    if (revealed) { return; }
   666	    revealed = true;
   667	    holding = false;
   668	    if (timer) { clearTimeout(timer); timer = null; }
   669	    zone.classList.remove("holding");
   670	    zone.classList.add("done");
   671	    btn.setAttribute("aria-expanded", "true");
   672	    revealPlain.setAttribute("aria-expanded", "true");
   673	    details.open = true;
   674	    requestAnimationFrame(function () { card.classList.add("revealed"); });
   675	    setStatus("Verified against the record. FAIL — 16 findings (11 error, 5 warn). Verdict shown below.");
   676	  }
   677	
   678	  function startHold() {
   679	    if (revealed || holding) { return; }
   680	    if (reduceMq.matches) { reveal(); return; }
   681	    holding = true;
   682	    zone.classList.add("holding");
   683	    setStatus("Verifying — hold to weigh the serving copy against the record.");
   684	    timer = setTimeout(reveal, HOLD_MS);
   685	  }
   686	
   687	  function cancelHold() {
   688	    if (!holding) { return; }
   689	    holding = false;
   690	    if (timer) { clearTimeout(timer); timer = null; }
   691	    zone.classList.remove("holding");
   692	    setStatus("Released early — the check did not complete. Hold again, or reveal without holding.");
   693	  }
   694	
   695	  btn.addEventListener("pointerdown", function (e) {
   696	    if (typeof e.button === "number" && e.button !== 0) { return; }
   697	    try { btn.setPointerCapture(e.pointerId); } catch (err) {}
   698	    e.preventDefault();
   699	    startHold();
   700	  });
   701	  btn.addEventListener("pointerup", function (e) {
   702	    try { btn.releasePointerCapture(e.pointerId); } catch (err) {}
   703	    cancelHold();
   704	  });
   705	  btn.addEventListener("pointercancel", cancelHold);
   706	  btn.addEventListener("pointerleave", cancelHold);
   707	
   708	  function isActivateKey(e) {
   709	    return e.key === " " || e.key === "Spacebar" || e.code === "Space" || e.key === "Enter";
   710	  }
   711	  btn.addEventListener("keydown", function (e) {
   712	    if (!isActivateKey(e)) { return; }
   713	    e.preventDefault();
   714	    if (e.repeat) { return; }
   715	    startHold();
   716	  });
   717	  btn.addEventListener("keyup", function (e) {
   718	    if (!isActivateKey(e)) { return; }
   719	    e.preventDefault();
   720	    cancelHold();
   721	  });
   722	  btn.addEventListener("blur", cancelHold);
   723	
   724	  revealPlain.addEventListener("click", function () { reveal(); });
   725	
   726	  details.open = false;
   727	
   728	  /* ------------------------ card reveal on scroll ------------------------ */
   729	  var reveals = Array.prototype.slice.call(document.querySelectorAll(".reveal"));
   730	  if ("IntersectionObserver" in window && !reduceMq.matches) {
   731	    var io = new IntersectionObserver(function (entries) {
   732	      entries.forEach(function (entry) {
   733	        if (!entry.isIntersecting) { return; }
   734	        var el = entry.target;
   735	        var delay = parseInt(el.getAttribute("data-stagger") || "0", 10) || 0;
   736	        setTimeout(function () { el.classList.add("in"); }, delay);
   737	        io.unobserve(el);
   738	      });
   739	    }, { threshold: 0.12, rootMargin: "0px 0px -6% 0px" });
   740	    reveals.forEach(function (el) { io.observe(el); });
   741	  } else {
   742	    reveals.forEach(function (el) { el.classList.add("in"); });
   743	  }
   744	})();
   745	</script>
