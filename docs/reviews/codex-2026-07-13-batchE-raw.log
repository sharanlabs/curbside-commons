     1	#!/usr/bin/env node
     2	/**
     3	 * Verifier CLI — W1 (plan §5 W1, C1: one-command validator).
     4	 *
     5	 * `check <feed.json> --against <catalog.json> [--surface acp|ucp] [--json]`
     6	 * Runs the deterministic drift verification and prints the machine-readable
     7	 * report (JSON). Exit codes: 0 = clean · 1 = findings (any drift) · 2 = usage /
     8	 * input error. This path performs ZERO LLM or network calls (C1: $0-LLM) — the
     9	 * comparator is loaded from the TypeScript source via Node's native
    10	 * type-stripping (Node ≥ 24) so there is exactly ONE implementation.
    11	 *
    12	 * Machine-JSON leg (W3, C1): the report IS the output — canonical
    13	 * `JSON.stringify(report, null, 2)` on stdout, always carrying the C10 header
    14	 * surface (specVersion pin · matchingMode · simulated). JSON is the default and
    15	 * only serialization; `--json` is an explicit, CI-friendly alias that requests
    16	 * it by name (trailing flag; the default is byte-identical, which is why the
    17	 * frozen golden reports stay locked). Exit-code semantics are unchanged.
    18	 *
    19	 * Plain: point it at the copy and the truth; it prints every catch with
    20	 * receipts (as machine-readable JSON a CI job can gate on) and fails loudly if
    21	 * the copy lies. Free to run, no AI calls.
    22	 */
    23	
    24	const USAGE = `verifier — deterministic serving-copy checker (simulated corpus)
    25	
    26	Usage:
    27	  check <feed.json> --against <catalog.json> [--surface acp|ucp] [--json]
    28	      TRUTH leg: verify a serving copy against the SOR catalog (does it LIE?).
    29	      Exit 0 = clean, 1 = drift found.
    30	  check <doc.json> --conformance [--op search|lookup|get_product] [--json]
    31	      CONFORMANCE leg: validate a UCP catalog-response document against the pinned
    32	      published UCP schemas (is it correctly SHAPED?). No --against needed — the
    33	      reference is the schema. Exit 0 = conformant, 1 = schema violation(s).
    34	  fees <statement.json> [--json]
    35	      FEE-AUDIT leg (F1a, UC-1): audit a monthly delivery fee statement against
    36	      the codified NYC §20-563.3 caps (deterministic, $0, no LLM). Classification
    37	      is AS-DECLARED by the platform — this CLI path is the deterministic
    38	      baseline and never invokes the separately-evaluated live LLM classifier
    39	      lane (calibrated 2026-07-09 on a pre-registered held-out split; advisory,
    40	      key-gated, reachable only through the tool-registry surface, never here).
    41	      Prints a two-register text report, or the machine report with --json.
    42	      Exit 0 = no violations, 1 = at least one violation, 2 = usage / bad input.
    43	  demo [--json]
    44	      DEMO leg (D1): play the scripted walkthrough on the shipped corpus — a
    45	      spec-faithful simulated agent follows a spec-valid but false surface; the
    46	      verifier catches the surface/SOR mismatch. Deterministic, $0, zero-config.
    47	      Prints plain text, or the machine transcript with --json. Always exit 0.
    48	  help
    49	      Show this message.
    50	
    51	Notes:
    52	  - No LLM / network calls on either path (C1: $0-LLM; conformance reads pinned
    53	    schemas from disk via ajv).
    54	  - Output is the machine-readable report (JSON) on stdout — CI-usable, always
    55	    carrying the C10 header surface (specVersion · matchingMode · simulated).
    56	    --json is the explicit, trailing alias for that default serialization.
    57	  - Unknown flags, surplus positionals, and mixed modes exit 2 (loud) — a typo
    58	    never silently falls back to a default, and --conformance never silently
    59	    swallows a truth-leg request (the legs are separate commands by design).
    60	  - conformance vs truth: a spec-VALID document can still be FALSE. The two legs
    61	    answer different questions and use distinct rule families (LST-* vs LST-CONF-*).
    62	  - --surface defaults to acp; --op defaults to search.
    63	  - Zero-config demos: npm run check:fixtures  |  npm run check:conformance
    64	`;
    65	
    66	/** @param {string[]} argv */
    67	async function main(argv) {
    68	  const args = argv.slice(2);
    69	  const cmd = args[0];
    70	
    71	  if (!cmd || cmd === "help" || cmd === "--help" || cmd === "-h") {
    72	    process.stdout.write(USAGE);
    73	    return 0;
    74	  }
    75	
    76	  // DEMO leg (D1): a scripted walkthrough. Strict-flag discipline mirrors the
    77	  // check legs — the ONLY accepted flag is --json; any other flag or any
    78	  // positional exits 2 loudly (a typo'd `demo --agdainst x` must never silently
    79	  // run the plain demo). Always exit 0 on success (it is a walkthrough, not a gate).
    80	  if (cmd === "demo") {
    81	    let json = false;
    82	    for (let i = 1; i < args.length; i++) {
    83	      const arg = args[i];
    84	      if (arg === "--json") {
    85	        json = true;
    86	        continue;
    87	      }
    88	      process.stderr.write(
    89	        `check: "demo" accepts only --json (got "${arg}")\n\n${USAGE}`,
    90	      );
    91	      return 2;
    92	    }
    93	    try {
    94	      const { runDemo } = await import("../lib/packs/listings/cli.ts");
    95	      const result = runDemo({ json });
    96	      process.stdout.write(result.output);
    97	      return result.exitCode;
    98	    } catch (err) {
    99	      process.stderr.write(`check: ${err instanceof Error ? err.message : String(err)}\n`);
   100	      return 2;
   101	    }
   102	  }
   103	
   104	  // FEES leg (F1a, UC-1): audit one monthly fee statement. Strict-flag discipline
   105	  // mirrors the other legs — the ONLY accepted flag is --json; any other flag or a
   106	  // surplus/absent positional exits 2 loudly (a typo must never silently run on a
   107	  // default). Exit 0 = no violations, 1 = ≥1 violation, 2 = usage / bad input.
   108	  if (cmd === "fees") {
   109	    let json = false;
   110	    const positionals = [];
   111	    for (let i = 1; i < args.length; i++) {
   112	      const arg = args[i];
   113	      if (arg === "--json") {
   114	        json = true;
   115	        continue;
   116	      }
   117	      if (arg.startsWith("--")) {
   118	        process.stderr.write(`check: "fees" accepts only --json (got "${arg}")\n\n${USAGE}`);
   119	        return 2;
   120	      }
   121	      positionals.push(arg);
   122	    }
   123	    if (positionals.length !== 1) {
   124	      process.stderr.write(
   125	        `check: "fees" needs exactly ONE <statement.json> (got ${positionals.length})\n\n${USAGE}`,
   126	      );
   127	      return 2;
   128	    }
   129	    try {
   130	      const { runFeeCheck } = await import("../lib/packs/fees/cli.ts");
   131	      const result = runFeeCheck(positionals[0], { json });
   132	      process.stdout.write(result.output);
   133	      return result.exitCode;
   134	    } catch (err) {
   135	      process.stderr.write(`check: ${err instanceof Error ? err.message : String(err)}\n`);
   136	      return 2;
   137	    }
   138	  }
   139	
   140	  if (cmd !== "check") {
   141	    process.stderr.write(`Unknown command: ${cmd}\n\n${USAGE}`);
   142	    return 2;
   143	  }
   144	
   145	  // Flags are validated loudly (W3): a typo'd flag must NEVER silently fall
   146	  // back to a default — CI would then gate on the wrong check. Known flags and
   147	  // how many value arguments each consumes:
   148	  const KNOWN_FLAGS = new Map([
   149	    ["--against", 1],
   150	    ["--surface", 1],
   151	    ["--conformance", 0],
   152	    ["--op", 1],
   153	    ["--json", 0],
   154	  ]);
   155	  const positionals = [];
   156	  for (let i = 1; i < args.length; i++) {
   157	    const arg = args[i];
   158	    if (!arg.startsWith("--")) {
   159	      positionals.push(arg);
   160	      continue;
   161	    }
   162	    if (!KNOWN_FLAGS.has(arg)) {
   163	      process.stderr.write(`check: unknown flag "${arg}"\n\n${USAGE}`);
   164	      return 2;
   165	    }
   166	    i += KNOWN_FLAGS.get(arg);
   167	  }
   168	
   169	  // Each leg takes exactly ONE input document; surplus positionals are a user
   170	  // error, not something to silently ignore (M1 reconciliation).
   171	  if (positionals.length > 1) {
   172	    process.stderr.write(
   173	      `check: expected ONE input file, got ${positionals.length} (${positionals.join(", ")})\n\n${USAGE}`,
   174	    );
   175	    return 2;
   176	  }
   177	
   178	  // The two legs answer DIFFERENT questions and are mutually exclusive: a
   179	  // mixed command must refuse loudly, or "--conformance --against sor.json"
   180	  // would silently skip the truth leg — and a conformant document can still
   181	  // lie (that is the program's headline). (M1 Codex P1.)
   182	  if (args.includes("--conformance") && (args.includes("--against") || args.includes("--surface"))) {
   183	    process.stderr.write(
   184	      `check: --conformance (shape) and --against/--surface (truth) are separate checks — run them as two commands\n\n${USAGE}`,
   185	    );
   186	    return 2;
   187	  }
   188	  // The converse hole (confirming-pass P3): --op is a conformance-leg option;
   189	  // accepting it on the truth leg would silently ignore it.
   190	  if (args.includes("--op") && !args.includes("--conformance")) {
   191	    process.stderr.write(`check: --op only applies to --conformance\n\n${USAGE}`);
   192	    return 2;
   193	  }
   194	
   195	  const feedPath = args[1];
   196	
   197	  // CONFORMANCE leg (W2): validate a UCP doc against the pinned schemas.
   198	  if (args.includes("--conformance")) {
   199	    const opIdx = args.indexOf("--op");
   200	    const op = opIdx >= 0 ? args[opIdx + 1] : "search";
   201	    if (!feedPath || feedPath.startsWith("--")) {
   202	      process.stderr.write(`check: --conformance needs <doc.json>\n\n${USAGE}`);
   203	      return 2;
   204	    }
   205	    if (op !== "search" && op !== "lookup" && op !== "get_product") {
   206	      process.stderr.write(`check: --op must be "search", "lookup" or "get_product" (got "${op}")\n\n${USAGE}`);
   207	      return 2;
   208	    }
   209	    try {
   210	      const { runConformanceCheck } = await import("../lib/packs/listings/cli.ts");
   211	      const result = runConformanceCheck(feedPath, op);
   212	      process.stdout.write(result.output);
   213	      return result.exitCode;
   214	    } catch (err) {
   215	      process.stderr.write(`check: ${err instanceof Error ? err.message : String(err)}\n`);
   216	      return 2;
   217	    }
   218	  }
   219	
   220	  // TRUTH leg (W1): verify a serving copy against the SOR catalog.
   221	  const againstIdx = args.indexOf("--against");
   222	  const catalogPath = againstIdx >= 0 ? args[againstIdx + 1] : undefined;
   223	  const surfaceIdx = args.indexOf("--surface");
   224	  const surface = surfaceIdx >= 0 ? args[surfaceIdx + 1] : "acp";
   225	
   226	  if (!feedPath || feedPath.startsWith("--") || !catalogPath) {
   227	    process.stderr.write(`check: need <feed.json> and --against <catalog.json>\n\n${USAGE}`);
   228	    return 2;
   229	  }
   230	  if (surface !== "acp" && surface !== "ucp") {
   231	    process.stderr.write(`check: --surface must be "acp" or "ucp" (got "${surface}")\n\n${USAGE}`);
   232	    return 2;
   233	  }
   234	
   235	  try {
   236	    const { runCheck } = await import("../lib/packs/listings/cli.ts");
   237	    const result = runCheck(feedPath, catalogPath, surface);
   238	    process.stdout.write(result.output);
   239	    return result.exitCode;
   240	  } catch (err) {
   241	    process.stderr.write(`check: ${err instanceof Error ? err.message : String(err)}\n`);
   242	    return 2;
   243	  }
   244	}
   245	
   246	process.exit(await main(process.argv));
     1	/**
     2	 * README demo visual — rendered FROM a real captured run (plan v3.4 RV2).
     3	 *
     4	 * Runs `node bin/check.mjs demo` (the same command the README documents),
     5	 * captures its stdout, and renders EVERY line verbatim into an animated SVG
     6	 * "terminal card". Nothing is staged: the SVG's text nodes are the captured
     7	 * bytes, XML-escaped. Deterministic — no clock, no randomness; the same demo
     8	 * output always yields the same SVG bytes.
     9	 *
    10	 * Motion: the demo's beats fade in sequentially (opacity-only, CSS inside the
    11	 * SVG), honoring prefers-reduced-motion (everything visible immediately).
    12	 * Ground is light per the standing no-dark-background preference.
    13	 *
    14	 * Usage: node scripts-ts/render-demo-svg.mts   → writes docs/assets/demo.svg
    15	 */
    16	import { execFileSync } from "node:child_process";
    17	import { mkdirSync, writeFileSync } from "node:fs";
    18	import { dirname, join, resolve } from "node:path";
    19	import { fileURLToPath } from "node:url";
    20	
    21	const root = resolve(dirname(fileURLToPath(import.meta.url)), "..");
    22	const OUT = join(root, "docs", "assets", "demo.svg");
    23	
    24	// ---- 1. The REAL run (captured verbatim) -----------------------------------
    25	const raw = execFileSync("node", [join(root, "bin", "check.mjs"), "demo"], {
    26	  encoding: "utf8",
    27	  cwd: root,
    28	});
    29	const lines = raw.replace(/\r\n/g, "\n").replace(/\n+$/, "").split("\n");
    30	
    31	// ---- 2. Geometry (derived from the capture, never hardcoded) ---------------
    32	const FONT = 13; // px, monospace
    33	const CHAR_W = FONT * 0.602; // ui-monospace advance approximation
    34	const LINE_H = 19;
    35	const PAD_X = 28;
    36	const PAD_TOP = 64; // chrome bar + breathing room
    37	const PAD_BOTTOM = 28;
    38	const maxCols = Math.max(...lines.map((l) => l.length));
    39	const width = Math.ceil(maxCols * CHAR_W + PAD_X * 2);
    40	const height = PAD_TOP + lines.length * LINE_H + PAD_BOTTOM;
    41	
    42	// ---- 3. Beat grouping for the sequential reveal -----------------------------
    43	// A new "beat block" starts at each `----`/`====` separator line; the reveal
    44	// staggers block by block so the story reads top-down like the live terminal.
    45	const isRule = (l: string) => /^[=-]{20,}$/.test(l.trim());
    46	let block = 0;
    47	const blockOf: number[] = lines.map((l, i) => {
    48	  if (i > 0 && isRule(l) && !isRule(lines[i - 1] ?? "")) block += 1;
    49	  return block;
    50	});
    51	const blockCount = block + 1;
    52	const STEP_S = 0.55; // delay between blocks
    53	const FADE_S = 0.5;
    54	
    55	// ---- 4. Verbatim line rendering (XML-escaped; classes are styling only) ----
    56	const esc = (s: string) =>
    57	  s.replace(/&/g, "&amp;").replace(/</g, "&lt;").replace(/>/g, "&gt;");
    58	const classFor = (l: string): string => {
    59	  if (/\[ERROR\]/.test(l)) return "err";
    60	  if (/\[FLAG\]/.test(l)) return "flag";
    61	  if (/\[OK\]/.test(l)) return "ok";
    62	  if (/^BEAT \d/.test(l.trim())) return "beat";
    63	  if (isRule(l)) return "rule";
    64	  if (/^\s*▸/.test(l)) return "note";
    65	  if (/^(claim|reference|rule|class):|^\s+(claim|reference|rule|class):/.test(l.trim())) return "receipt";
    66	  return "body";
    67	};
    68	const text = lines
    69	  .map((l, i) => {
    70	    const y = PAD_TOP + (i + 1) * LINE_H - 6;
    71	    const cls = classFor(l);
    72	    return `<text x="${PAD_X}" y="${y}" class="ln b${blockOf[i]} ${cls}" xml:space="preserve">${esc(l)}</text>`;
    73	  })
    74	  .join("\n");
    75	
    76	const delays = Array.from({ length: blockCount }, (_, i) =>
    77	  `.b${i}{animation-delay:${(i * STEP_S).toFixed(2)}s}`,
    78	).join("");
    79	
    80	// ---- 5. The SVG -------------------------------------------------------------
    81	const svg = `<svg xmlns="http://www.w3.org/2000/svg" width="${width}" height="${height}" viewBox="0 0 ${width} ${height}" role="img" aria-label="Captured terminal run of: node bin/check.mjs demo — a simulated agent trusts a spec-valid feed; the deterministic verifier flags the price drift with receipts. Simulated data.">
    82	<title>node bin/check.mjs demo — real captured output (simulated data)</title>
    83	<style>
    84	  .card{fill:#ffffff;stroke:#d9d4cc;stroke-width:1}
    85	  .bar{fill:#f6f4f0}
    86	  .dot{fill:#c9c2b8}
    87	  .cmd{font:600 ${FONT}px ui-monospace,SFMono-Regular,Menlo,Consolas,monospace;fill:#5c5648}
    88	  .ln{font:${FONT}px ui-monospace,SFMono-Regular,Menlo,Consolas,monospace;fill:#2b2620;opacity:0;animation:in ${FADE_S}s cubic-bezier(0.23,1,0.32,1) forwards}
    89	  .rule{fill:#b3aca0}
    90	  .beat{fill:#1a1712;font-weight:700}
