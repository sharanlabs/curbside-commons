   466	
   467	  /* ===================== the living mark: draw + scroll ================ */
   468	  /* shield + check draw once on load (identity); the outer ring is the scroll
   469	     progress indicator that advances as you descend. */
   470	  @media (prefers-reduced-motion: no-preference) {
   471	    .seal .shield, .seal .check {
   472	      stroke-dasharray: 1; stroke-dashoffset: 1; animation: sealdraw 1100ms var(--ease-out) forwards;
   473	    }
   474	    .seal .check { animation-delay: 520ms; }
   475	    .seal .ringtext { opacity: 0; animation: sealfade 700ms var(--ease-out) 900ms forwards; }
   476	  }
   477	  @keyframes sealdraw { to { stroke-dashoffset: 0; } }
   478	  @keyframes sealfade { to { opacity: 1; } }
   479	
   480	  /* CSS scroll-driven progress ring — no JS required where supported */
   481	  @supports (animation-timeline: scroll()) {
