   166	    signatureOk = edVerify(null, payload, signer.publicKey, Buffer.from(decision.signatureBase64, "base64"));
   167	  } catch {
   168	    signatureOk = false; // malformed base64 / wrong key type — same loud outcome
   169	  }
   170	  if (!signatureOk) {
   171	    throw new SignatureInvalidError(
   172	      `signature by "${decision.signerKeyId}" does not verify over the canonical payload`,
   173	    );
   174	  }
   175	  // 7 — content binding: the SIGNED digest must be THIS request's content.
   176	  if (decision.subjectDigest !== request.subjectDigest) {
   177	    throw new SubjectMismatchError(
   178	      `decision is signed over content ${decision.subjectDigest.slice(0, 12)}…, but this request covers ${request.subjectDigest.slice(0, 12)}…`,
   179	    );
   180	  }
   181	
   182	  // All seven held — consume the nonce, then execute (= record, nothing else).
   183	  opts.seenNonces.add(request.nonce);
   184	  return Object.freeze({
   185	    executed: true,
   186	    requestId: request.requestId,
   187	    caseId: request.caseId,
   188	    action: request.action,
   189	    decision: decision.decision,
   190	    signerKeyId: decision.signerKeyId,
   191	    signerRole: signer.role,
   192	    subjectDigest: request.subjectDigest,
   193	    decidedAtMs: decision.decidedAtMs,
   194	    verifiedAtMs: now,
   195	    reason: "all seven verification checks passed (SIMULATED offline approvals lane)",
   196	    auditLine: `SIMULATED-APPROVAL executed=${true} request=${request.requestId} case=${request.caseId} action=${request.action} decision=${decision.decision} signer=${decision.signerKeyId} verifiedAt=${now}`,
   197	  });
   198	}
     1	/**
     2	 * E3 APPROVALS TYPES — the typed vocabulary of the OFFLINE MCP-Slack approvals
     3	 * SIMULATOR (plan `docs/plan-debrand-design-armoury-2026-07-09.md` §E3, Tier-3
     4	 * #3). This module simulates — fully offline, at $0, with zero transport — the
     5	 * future live "sign a human approval in Slack, then execute" lane. That live
     6	 * interactive lane is NOT built here and stays a future owner word; everything
     7	 * in `lib/approvals/**` is SIMULATED per RULES §4.
     8	 *
     9	 * THE THREAT MODEL these types encode (why each field exists):
    10	 *  - signer identity + authorization: a decision is trusted only if its
    11	 *    `signerKeyId` resolves to a registered public key AND that signer holds the
    12	 *    required role. The keyId→publicKey binding is the trust anchor — a forged
    13	 *    signature (a different private key claiming a registered keyId) fails.
    14	 *  - content binding: `subjectDigest` is the sha256 of the crew record's
    15	 *    canonical content, so a signed decision cannot be re-bound to a DIFFERENT
    16	 *    crew record — the digest travels inside the signed payload AND is
    17	 *    cross-checked against the request.
    18	 *  - replay: `nonce` is a per-request single-use token; a nonce seen once can
    19	 *    never execute again (globally, across requests).
    20	 *  - expiry: `expiresAtMs` vs an INJECTED clock makes staleness testable; there
    21	 *    is no ambient `Date.now()` anywhere in this module.
    22	 *  - tamper/forgery: the signature is verified over a payload RECOMPUTED from
    23	 *    canonical bytes — never trusted from the wire.
    24	 *
    25	 * KEY HANDLING: no key material is defined, stored, or serialized here. Public
    26	 * keys arrive at verify time in the caller's `authorizedSigners` map; private
    27	 * keys exist only inside a signer's device (in tests/simulation, a runtime-
    28	 * generated ephemeral keypair). No `ExecutionRecord` — the simulator's only
    29	 * output — ever carries key bytes or transport fields.
    30	 *
    31	 * Plain: this is a paper-only rehearsal of "a human signs off in Slack, then the
    32	 * action runs." Nothing here can talk to Slack or change anything real. Each
    33	 * approval is cryptographically tied to exactly what was reviewed, to a specific
    34	 * person, for a short window, and can be used exactly once — and the rehearsal
    35	 * proves all of that with tests instead of trusting anyone's word.
    36	 */
    37	import type { KeyObject } from "node:crypto";
    38	import type { TrajectoryTerminal } from "../crew/types.ts";
    39	
    40	/** A monotonic time source — the ONLY way this module learns "now" (determinism + testable expiry). */
    41	export interface Clock {
    42	  /** Current time in epoch milliseconds. Pure: no ambient clock, no side effects. */
    43	  nowMs(): number;
    44	}
    45	
    46	/** The three approval flows. Derived from a crew record's terminal; see `resolveAction`. */
    47	export type ApprovalAction = "approve-recommendation" | "reject-recommendation" | "acknowledge-escalation";
    48	
    49	/** A signed human verdict. Orthogonal to the flow: within any flow a human may approve or reject. */
    50	export type ApprovalVerdict = "approve" | "reject";
    51	
    52	/** An opaque signer role (e.g. "approver"). Compared for EXACT equality against `requiredRole`. */
    53	export type SignerRole = string;
    54	
    55	/**
    56	 * The minimal crew-contract shape the simulator consumes READ-ONLY. A full
    57	 * `TrajectoryRecord` from `lib/crew/types.ts` is structurally assignable; only
    58	 * `terminal` (to pick the flow) and `caseId` (to label the request) are read
    59	 * directly, but the ENTIRE object passed is hashed into `subjectDigest`.
    60	 */
    61	export interface CrewRecordForApproval {
    62	  readonly caseId: string;
    63	  readonly terminal: TrajectoryTerminal;
    64	}
    65	
    66	/**
    67	 * A request for a signed human decision. Created from a crew record; carries the
    68	 * content binding (`subjectDigest`), the single-use `nonce`, and the validity
    69	 * window. Never carries any transport, channel, or recipient field.
    70	 */
    71	export interface ApprovalRequest {
    72	  readonly requestId: string;
    73	  readonly caseId: string;
    74	  readonly action: ApprovalAction;
    75	  /** sha256 (hex) of the canonical serialization of the crew record this request approves. */
    76	  readonly subjectDigest: string;
    77	  readonly requestedAtMs: number;
    78	  readonly expiresAtMs: number;
    79	  /** Single-use anti-replay token (globally unique; consumed on first verified execution). */
    80	  readonly nonce: string;
    81	}
    82	
    83	/**
    84	 * The six fields the Ed25519 signature covers. The ONE canonical serialization
    85	 * of exactly these keys (sorted, no whitespace) is documented in `canonical.ts`
    86	 * — a key-order or type-confusion variance would be signature malleability.
    87	 */
    88	export interface SigningPayloadFields {
    89	  readonly requestId: string;
    90	  readonly decision: ApprovalVerdict;
    91	  readonly signerKeyId: string;
    92	  readonly decidedAtMs: number;
    93	  readonly subjectDigest: string;
    94	  readonly nonce: string;
    95	}
    96	
    97	/**
    98	 * A signed human decision. The signature is Ed25519 over the canonical
    99	 * serialization of {requestId, decision, signerKeyId, decidedAtMs, subjectDigest,
   100	 * nonce} (the last, `nonce`, is the REQUEST's nonce at signing time; see
   101	 * `signDecision`). `subjectDigest` is carried here — not sourced from the request
   102	 * at verify time — so the "does this decision bind to THIS request's content?"
   103	 * check is an explicit, independently-testable step (see verify step 7).
   104	 */
   105	export interface SignedDecision {
   106	  readonly requestId: string;
   107	  readonly decision: ApprovalVerdict;
   108	  readonly signerKeyId: string;
   109	  readonly decidedAtMs: number;
   110	  /** The signer's attested content digest (part of the signed payload; cross-checked vs the request). */
   111	  readonly subjectDigest: string;
   112	  /** Base64 of the raw 64-byte Ed25519 signature over the canonical payload. */
   113	  readonly signatureBase64: string;
   114	}
   115	
   116	/** A registered signer: its public key (the trust anchor) and its authorized role. */
   117	export interface AuthorizedSigner {
   118	  readonly publicKey: KeyObject;
   119	  readonly role: SignerRole;
   120	}
   121	
   122	/** Options for {@link verifyAndExecute}. All time comes from `clock`; `seenNonces` is caller-owned, mutated on success. */
   123	export interface VerifyOptions {
   124	  readonly clock: Clock;
   125	  readonly authorizedSigners: ReadonlyMap<string, AuthorizedSigner>;
   126	  /** Mutable set of already-consumed nonces. A verified execution ADDS its nonce here. */
   127	  readonly seenNonces: Set<string>;
   128	  readonly requiredRole: SignerRole;
   129	}
   130	
   131	/**
   132	 * The verified outcome — the simulator's ONLY effect. Contains an append-only
   133	 * audit line and the decided facts. It NEVER carries key material or any
   134	 * transport/channel/recipient field (proven by a record-output scan in the
   135	 * threat-model suite). `executed` is always `true` on a returned record: the
   136	 * only way NOT to execute is a thrown typed error (loud, never a silent false).
   137	 */
   138	export interface ExecutionRecord {
   139	  readonly executed: boolean;
   140	  readonly requestId: string;
   141	  readonly caseId: string;
   142	  readonly action: ApprovalAction;
   143	  readonly decision: ApprovalVerdict;
   144	  readonly signerKeyId: string;
   145	  readonly signerRole: SignerRole;
   146	  readonly subjectDigest: string;
   147	  readonly decidedAtMs: number;
   148	  readonly verifiedAtMs: number;
   149	  readonly reason: string;
   150	  /** A deterministic single-line, append-only audit entry. No secrets, no transport. */
   151	  readonly auditLine: string;
   152	}
   153	
   154	/** Stable machine codes for every failure mode — one per frozen verify check. */
   155	export type ApprovalErrorCode =
   156	  | "REQUEST_MISMATCH"
   157	  | "EXPIRED"
   158	  | "REPLAY"
   159	  | "UNAUTHORIZED_SIGNER"
   160	  | "ROLE_NOT_AUTHORIZED"
   161	  | "SIGNATURE_INVALID"
   162	  | "SUBJECT_MISMATCH";
   163	
   164	/** Base class for every approval failure. Each failure is one of these — loud, typed, never a boolean false. */
   165	export class ApprovalError extends Error {
   166	  readonly code: ApprovalErrorCode;
   167	  constructor(code: ApprovalErrorCode, message: string) {
   168	    super(message);
   169	    // new.target.name resolves to the concrete subclass (e.g. "ReplayError").
   170	    this.name = new.target.name;
   171	    this.code = code;
   172	  }
   173	}
   174	
   175	/** Step 1: the signed decision's requestId does not match the request (verdicts are orthogonal to the flow — see {@link ApprovalVerdict}). */
   176	export class RequestMismatchError extends ApprovalError {
   177	  constructor(message: string) {
   178	    super("REQUEST_MISMATCH", message);
   179	  }
   180	}
   181	
   182	/** Step 2: the request has expired (clock ≥ expiresAtMs — expired AT the boundary). */
   183	export class ExpiredError extends ApprovalError {
   184	  constructor(message: string) {
   185	    super("EXPIRED", message);
   186	  }
   187	}
   188	
   189	/** Step 3: this nonce has already been consumed — a replay. */
   190	export class ReplayError extends ApprovalError {
   191	  constructor(message: string) {
   192	    super("REPLAY", message);
   193	  }
   194	}
   195	
   196	/** Step 4: the signerKeyId resolves to no registered public key (authentication failure). */
   197	export class UnauthorizedSignerError extends ApprovalError {
   198	  constructor(message: string) {
   199	    super("UNAUTHORIZED_SIGNER", message);
   200	  }
   201	}
   202	
   203	/** Step 5: a known signer, but its role is not the required role (authorization failure). */
   204	export class RoleNotAuthorizedError extends ApprovalError {
   205	  constructor(message: string) {
   206	    super("ROLE_NOT_AUTHORIZED", message);
   207	  }
   208	}
   209	
   210	/** Step 6: the signature does not verify over the recomputed canonical payload (tamper/forgery/empty). */
   211	export class SignatureInvalidError extends ApprovalError {
   212	  constructor(message: string) {
   213	    super("SIGNATURE_INVALID", message);
   214	  }
   215	}
   216	
   217	/** Step 7: a validly-signed decision whose attested subjectDigest is bound to a DIFFERENT crew record than the request. */
   218	export class SubjectMismatchError extends ApprovalError {
   219	  constructor(message: string) {
   220	    super("SUBJECT_MISMATCH", message);
   221	  }
   222	}
     1	/**
     2	 * E3 — the THREAT-MODEL suite (plan §E3): every registered threat gets its
     3	 * own test against the frozen seven-check order — signer identity,
     4	 * authorization (role), forgery, tamper (payload + digest re-binding),
     5	 * replay (same request + cross-request), expiry via the injected clock
     6	 * (before/at/after the boundary), request mismatch, empty signature — plus
     7	 * the key-handling scan proving no private material can appear in the
     8	 * simulator's only output.
     9	 *
    10	 * Keypairs are generated AT RUNTIME (never committed — RULES §11); the crew
    11	 * record fixture is typed against the real crew contract
    12	 * (`lib/crew/types.ts`) but constructed inline (evals/crew fixtures stay
    13	 * untouched).
    14	 *
    15	 * Plain: we attack our own approval flow every way we could think of —
    16	 * forged signatures, reused approvals, stale approvals, the wrong person,
    17	 * the right person with the wrong powers, paperwork swapped between cases —
    18	 * and prove each attack dies on its own specific locked door.
    19	 */
    20	import { generateKeyPairSync, sign as cryptoSign } from "node:crypto";
    21	import { describe, expect, it } from "vitest";
    22	
    23	import { canonicalSigningBytes } from "@/lib/approvals/canonical.ts";
    24	import {
    25	  createApprovalRequest,
    26	  resolveAction,
    27	  signDecision,
    28	  subjectDigestOf,
    29	  verifyAndExecute,
    30	} from "@/lib/approvals/simulator.ts";
    31	import {
    32	  ExpiredError,
    33	  ReplayError,
    34	  RequestMismatchError,
    35	  RoleNotAuthorizedError,
    36	  SignatureInvalidError,
    37	  SubjectMismatchError,
    38	  UnauthorizedSignerError,
    39	  type AuthorizedSigner,
    40	  type Clock,
    41	  type CrewRecordForApproval,
    42	} from "@/lib/approvals/types.ts";
    43	
    44	// ── runtime-generated signers (never committed) ─────────────────────────────
    45	const owner = generateKeyPairSync("ed25519");
    46	const reviewer = generateKeyPairSync("ed25519");
    47	const stranger = generateKeyPairSync("ed25519");
    48	
    49	const ROSTER: ReadonlyMap<string, AuthorizedSigner> = new Map([
    50	  ["owner-key-1", { publicKey: owner.publicKey, role: "approver" }],
    51	  ["reviewer-key-1", { publicKey: reviewer.publicKey, role: "observer" }],
    52	]);
    53	
    54	const fixedClock = (ms: number): Clock => ({ nowMs: () => ms });
    55	
    56	// A crew-record-shaped subject (typed against the real contract; extra fields
    57	// are part of the hashed content, as they would be on a full record).
    58	const crewRecord: CrewRecordForApproval & { engineReportHash: string; steps: string[] } = {
    59	  caseId: "int-approve-clean",
    60	  terminal: "recommendation",
    61	  engineReportHash: "sha256:2f6b3f9a0d1c",
    62	  steps: ["intake", "audit", "evidence", "reviewer"],
    63	};
    64	
    65	const T0 = 1_752_000_000_000; // fixed epoch base for the whole suite
    66	const TTL = 60_000;
    67	
    68	function freshFlow(nonce: string) {
    69	  const request = createApprovalRequest(crewRecord, { clock: fixedClock(T0), ttlMs: TTL, nonce });
    70	  const decision = signDecision(request, "approve", owner.privateKey, "owner-key-1", fixedClock(T0 + 1_000));
    71	  const opts = {
    72	    clock: fixedClock(T0 + 2_000),
    73	    authorizedSigners: ROSTER,
    74	    seenNonces: new Set<string>(),
    75	    requiredRole: "approver",
    76	  };
    77	  return { request, decision, opts };
    78	}
    79	
    80	describe("E3 happy paths", () => {
    81	  it("approve on a recommendation terminal executes with a full audit line", () => {
    82	    const { request, decision, opts } = freshFlow("n-happy-1");
    83	    const record = verifyAndExecute(request, decision, opts);
    84	    expect(record.executed).toBe(true);
    85	    expect(record.action).toBe("approve-recommendation");
    86	    expect(record.decision).toBe("approve");
    87	    expect(record.signerKeyId).toBe("owner-key-1");
    88	    expect(record.auditLine).toContain("SIMULATED-APPROVAL");
    89	    expect(record.auditLine).toContain(request.requestId);
    90	    expect(opts.seenNonces.has("n-happy-1")).toBe(true);
    91	  });
    92	
    93	  it("reject is a first-class verified outcome (not an error)", () => {
    94	    const { request, opts } = freshFlow("n-happy-2");
    95	    const decision = signDecision(request, "reject", owner.privateKey, "owner-key-1", fixedClock(T0 + 1_000));
    96	    const record = verifyAndExecute(request, decision, opts);
    97	    expect(record.executed).toBe(true);
    98	    expect(record.decision).toBe("reject");
    99	  });
   100	
   101	  it("an escalate-to-human terminal yields the acknowledge-escalation flow", () => {
   102	    const escalated = { ...crewRecord, caseId: "int-escalate-1", terminal: "escalate-to-human" as const };
   103	    const request = createApprovalRequest(escalated, { clock: fixedClock(T0), ttlMs: TTL, nonce: "n-esc-1" });
   104	    expect(request.action).toBe("acknowledge-escalation");
   105	    expect(resolveAction("escalate-to-human")).toBe("acknowledge-escalation");
   106	    const decision = signDecision(request, "approve", owner.privateKey, "owner-key-1", fixedClock(T0 + 1));
   107	    const record = verifyAndExecute(request, decision, {
   108	      clock: fixedClock(T0 + 2),
   109	      authorizedSigners: ROSTER,
   110	      seenNonces: new Set(),
   111	      requiredRole: "approver",
   112	    });
   113	    expect(record.action).toBe("acknowledge-escalation");
   114	  });
   115	});
   116	
   117	describe("E3 threats — each dies on its own typed door", () => {
   118	  it("UNAUTHORIZED SIGNER: an unregistered keyId is rejected before any crypto", () => {
   119	    const { request, opts } = freshFlow("n-t1");
   120	    const decision = signDecision(request, "approve", stranger.privateKey, "stranger-key-9", fixedClock(T0 + 1));
   121	    expect(() => verifyAndExecute(request, decision, opts)).toThrow(UnauthorizedSignerError);
   122	  });
   123	
   124	  it("WRONG ROLE: a known signer without the required role is rejected", () => {
   125	    const { request, opts } = freshFlow("n-t2");
   126	    const decision = signDecision(request, "approve", reviewer.privateKey, "reviewer-key-1", fixedClock(T0 + 1));
   127	    expect(() => verifyAndExecute(request, decision, opts)).toThrow(RoleNotAuthorizedError);
   128	  });
   129	
   130	  it("FORGERY: a stranger's signature under a registered keyId fails signature verification", () => {
   131	    const { request, opts } = freshFlow("n-t3");
   132	    const forged = signDecision(request, "approve", stranger.privateKey, "owner-key-1", fixedClock(T0 + 1));
   133	    expect(() => verifyAndExecute(request, forged, opts)).toThrow(SignatureInvalidError);
   134	  });
   135	
   136	  it("TAMPER: flipping the decision after signing invalidates the signature", () => {
   137	    const { request, decision, opts } = freshFlow("n-t4");
   138	    const tampered = { ...decision, decision: "reject" as const };
   139	    expect(() => verifyAndExecute(request, tampered, opts)).toThrow(SignatureInvalidError);
   140	  });
   141	
   142	  it("RE-BINDING: a validly-signed decision for a DIFFERENT crew record dies on the digest cross-check", () => {
   143	    const otherRecord = { ...crewRecord, caseId: "int-other-case", engineReportHash: "sha256:ffff" };
   144	    const otherRequest = createApprovalRequest(otherRecord, { clock: fixedClock(T0), ttlMs: TTL, nonce: "n-t5" });
   145	    const { request, opts } = freshFlow("n-t5"); // same nonce, same id shape? ids differ by caseId
   146	    // Sign honestly over the OTHER request, then present it against THIS one.
   147	    const foreign = signDecision(otherRequest, "approve", owner.privateKey, "owner-key-1", fixedClock(T0 + 1));
   148	    const rebound = { ...foreign, requestId: request.requestId };
   149	    // The requestId in the signed payload no longer matches -> signature dies
   150	    // first (the payload is recomputed); prove the digest door too by signing
   151	    // a decision whose payload uses THIS request's id but the other digest:
   152	    expect(() => verifyAndExecute(request, rebound, opts)).toThrow(SignatureInvalidError);
   153	    expect(subjectDigestOf(otherRecord)).not.toBe(request.subjectDigest);
   154	  });
   155	
   156	  it("DIGEST DOOR (step 7): a signature crafted over THIS request's id+nonce but a FOREIGN content digest dies on SubjectMismatchError", () => {
   157	    const { request, opts } = freshFlow("n-t5b");
   158	    const foreignDigest = subjectDigestOf({ ...crewRecord, caseId: "int-a-different-case" });
   159	    expect(foreignDigest).not.toBe(request.subjectDigest);
   160	    // Hand-craft the signed payload (a malicious-but-key-holding signer):
   161	    // valid id, valid nonce, valid key — but attesting different content.
   162	    const decidedAtMs = T0 + 1_000;
   163	    const payload = canonicalSigningBytes({
   164	      requestId: request.requestId,
   165	      decision: "approve",
   166	      signerKeyId: "owner-key-1",
   167	      decidedAtMs,
   168	      subjectDigest: foreignDigest,
   169	      nonce: request.nonce,
   170	    });
   171	    const crafted = {
   172	      requestId: request.requestId,
   173	      decision: "approve" as const,
   174	      signerKeyId: "owner-key-1",
   175	      decidedAtMs,
   176	      subjectDigest: foreignDigest,
   177	      signatureBase64: cryptoSign(null, payload, owner.privateKey).toString("base64"),
   178	    };
