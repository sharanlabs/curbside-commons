     1	/**
     2	 * E4 — name normalization, incl. the BASELINE chain frozen by pre-reg
     3	 * AMENDMENT A2, EXACTLY: NFKC → casefold → collapse whitespace → strip
     4	 * punctuation → strip the enumerated legal-suffix list {llc, inc, corp, co,
     5	 * ltd, dba, d.b.a.} (after punctuation-strip, "d.b.a." IS "dba", so the
     6	 * token list is {llc, inc, corp, co, ltd, dba}, removed only as trailing
     7	 * tokens, repeatedly). No post-hoc changes — any change = a new
     8	 * pre-registration.
     9	 *
    10	 * Plain: the standard cleanup both the dumb baseline and the fancier matcher
    11	 * share — lowercase it, tidy the spaces and dots, drop "LLC"-style tails —
    12	 * locked in writing before any grading happened.
    13	 */
    14	
    15	const LEGAL_SUFFIX_TOKENS = new Set(["llc", "inc", "corp", "co", "ltd", "dba"]);
    16	
    17	/** The A2 baseline normalization chain (frozen). */
    18	export function baselineNormalize(name: string): string {
    19	  const cleaned = name
    20	    .normalize("NFKC")
    21	    .toLowerCase() // casefold (ASCII-adequate for this fictional corpus; NFKC precedes)
    22	    .replace(/\s+/gu, " ")
    23	    .trim()
    24	    .replace(/[^\p{L}\p{N}\s]/gu, "")
    25	    .replace(/\s+/gu, " ")
    26	    .trim();
    27	  const tokens = cleaned.split(" ").filter((t) => t.length > 0);
    28	  while (tokens.length > 1 && LEGAL_SUFFIX_TOKENS.has(tokens[tokens.length - 1])) {
    29	    tokens.pop();
    30	  }
    31	  return tokens.join(" ");
    32	}
    33	
    34	/** Baseline matcher (the PROTECTED DEFAULT): SAME iff normalized-exact equal; never abstains. */
    35	export function baselineVerdict(a: string, b: string): "SAME" | "DIFFERENT" {
    36	  return baselineNormalize(a) === baselineNormalize(b) ? "SAME" : "DIFFERENT";
    37	}
     1	/**
     2	 * E4 — the ADVISORY entity-resolution ensemble (pre-reg §1/§4).
     3	 *
     4	 * ARCHITECTURE, restated where the code lives: this matcher is ADVISORY and
     5	 * can NEVER gate — it proposes candidate matches with scores; nothing in the
     6	 * verification engine imports this module (a structural eval proves that),
     7	 * EXACT matching remains the protected default everywhere the engine
     8	 * consumes identity, and every score inside the registered ambiguity band
     9	 * routes to a human (ABSTAIN). Its worst failure — a FALSE MERGE — attaches
    10	 * one business's findings to another business; that named cost is why the
    11	 * floors are precision-weighted and below-threshold NEVER auto-merges.
    12	 *
    13	 * Ensemble (weights registered here, frozen with the thresholds BEFORE
    14	 * scoring): 0.5 · Jaro-Winkler(normalized) + 0.35 · token-set ratio +
    15	 * 0.15 · phonetic (Soundex token-set). Inputs are baseline-normalized first
    16	 * (the SAME A2 chain the baseline uses — the ensemble's edge must come from
    17	 * fuzzy similarity, not from a private normalizer the baseline is denied).
    18	 *
    19	 * Plain: three rulers vote on how alike two names are; a high blend proposes
    20	 * "probably the same business," a low blend "different," and the middle says
    21	 * "ask a human." It only ever SUGGESTS — the checker itself still requires
    22	 * exact identity.
    23	 */
    24	import { baselineNormalize } from "./normalize.ts";
    25	import { jaroWinkler, phoneticSimilarity, tokenSetRatio } from "./similarity.ts";
    26	
    27	export const ENSEMBLE_WEIGHTS = Object.freeze({ jaroWinkler: 0.5, tokenSet: 0.35, phonetic: 0.15 });
    28	
    29	export type MatchVerdict = "SAME" | "DIFFERENT" | "ABSTAIN";
    30	
    31	export interface MatchResult {
    32	  readonly a: string;
    33	  readonly b: string;
    34	  readonly normalizedA: string;
    35	  readonly normalizedB: string;
    36	  readonly score: number;
    37	  readonly verdict: MatchVerdict;
    38	  /** Always true — this lane cannot gate anything (pre-reg §1). */
    39	  readonly advisory: true;
    40	  /** The registered scope label, rendered wherever E4 surfaces. */
    41	  readonly scopeLabel: string;
    42	}
    43	
    44	export const E4_SCOPE_LABEL =
    45	  "entity resolution validated on a SYNTHETIC adversarial name corpus — advisory only; exact matching remains the system default";
    46	
    47	/** The blended similarity score in [0, 1]. */
    48	export function ensembleScore(a: string, b: string): number {
    49	  const na = baselineNormalize(a);
    50	  const nb = baselineNormalize(b);
    51	  return (
    52	    ENSEMBLE_WEIGHTS.jaroWinkler * jaroWinkler(na, nb) +
    53	    ENSEMBLE_WEIGHTS.tokenSet * tokenSetRatio(na, nb) +
    54	    ENSEMBLE_WEIGHTS.phonetic * phoneticSimilarity(na, nb)
    55	  );
    56	}
    57	
    58	/**
    59	 * Propose a match under the two frozen thresholds (T_match > T_abstain,
    60	 * tuned on the tune split ONLY, committed before scoring): score ≥ T_match →
    61	 * SAME; score ≤ T_abstain → DIFFERENT; between → ABSTAIN to the human.
    62	 */
    63	export function proposeMatch(a: string, b: string, tMatch: number, tAbstain: number): MatchResult {
    64	  if (!(tMatch > tAbstain)) {
    65	    throw new Error(`E4: T_match (${tMatch}) must be strictly greater than T_abstain (${tAbstain})`);
    66	  }
    67	  const score = ensembleScore(a, b);
    68	  const verdict: MatchVerdict = score >= tMatch ? "SAME" : score <= tAbstain ? "DIFFERENT" : "ABSTAIN";
    69	  return {
    70	    a,
    71	    b,
    72	    normalizedA: baselineNormalize(a),
    73	    normalizedB: baselineNormalize(b),
    74	    score,
    75	    verdict,
    76	    advisory: true,
    77	    scopeLabel: E4_SCOPE_LABEL,
    78	  };
    79	}

codex
Two material preregistration concerns have emerged and I’m validating them against the exact frozen text and code paths: E2’s M5 grader appears to narrow “every/full serialized output field” to selected decision fields after gold exposure, and E4’s test corpus appears to contain 10 trap cases despite the original preregistered minimum of 12. I’m also checking whether coordinated snapshot+manifest edits evade the claimed A1 hard block and whether E3 signs every execution-relevant request field.
