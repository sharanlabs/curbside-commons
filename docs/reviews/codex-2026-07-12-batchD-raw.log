     1	/**
     2	 * Git blob-hash utility + the E2 corpus-manifest HARD-BLOCK gate
     3	 * (pre-registration AMENDMENT A1).
     4	 *
     5	 * The corpus is pinned to exact git blob hashes at `31bd66d`. This gate
     6	 * recomputes each file's blob sha1 IN PURE TS from bytes — `sha1("blob " +
     7	 * byteLength + "\0" + bytes)` (git's object encoding) — so the check needs no
     8	 * git subprocess and runs identically in CI. Any mismatch, missing file, or
     9	 * unmanifested file inside the schema tree is a HARD BLOCK: the thrown error
    10	 * stops both the vitest gate and the scoring harness (which calls this before
    11	 * touching the index).
    12	 *
    13	 * Plain: before the lookup feature is allowed to run, it re-fingerprints every
    14	 * source document and compares against the fingerprints frozen in the
    15	 * pre-registration — if even one byte moved, everything stops loudly.
    16	 */
    17	import { createHash } from "node:crypto";
    18	import { readFileSync, readdirSync, statSync } from "node:fs";
    19	import { join } from "node:path";
    20	
    21	/** git blob sha1 of a byte buffer (git object encoding). */
    22	export function gitBlobSha1(bytes: Buffer): string {
    23	  const header = Buffer.from(`blob ${bytes.byteLength}\0`, "utf8");
    24	  return createHash("sha1").update(Buffer.concat([header, bytes])).digest("hex");
    25	}
    26	
    27	export interface CorpusSourcePin {
    28	  /** Repo-relative path. */
    29	  readonly path: string;
    30	  /** Full git blob sha1 the file must hash to. */
    31	  readonly blobSha1: string;
    32	}
    33	
    34	export interface CorpusManifestPins {
    35	  /** Every pinned corpus file (schema tree expanded per-file). */
    36	  readonly sources: readonly CorpusSourcePin[];
    37	  /** Directory whose ENTIRE recursive file set must equal its manifest subset. */
    38	  readonly exhaustiveDir: string;
    39	}
    40	
    41	/** Recursively list files under a directory (repo-relative paths). */
    42	function walkFiles(root: string, dir: string): string[] {
    43	  return readdirSync(join(root, dir)).flatMap((name) => {
    44	    const rel = `${dir}/${name}`;
    45	    return statSync(join(root, rel)).isDirectory() ? walkFiles(root, rel) : [rel];
    46	  });
    47	}
    48	
    49	/**
    50	 * The A1 gate. Throws (HARD BLOCK) on: a pinned file whose recomputed blob
    51	 * sha1 differs, a pinned file that cannot be read, or a file present under
    52	 * `exhaustiveDir` that is not in the manifest (silent additions count as
    53	 * drift too). Returns the verified pin list on success.
    54	 */
    55	export function assertCorpusPins(repoRoot: string, pins: CorpusManifestPins): readonly CorpusSourcePin[] {
    56	  for (const src of pins.sources) {
    57	    let bytes: Buffer;
    58	    try {
    59	      bytes = readFileSync(join(repoRoot, src.path));
    60	    } catch (e) {
    61	      throw new Error(`E2 corpus HARD BLOCK: pinned source unreadable: ${src.path} (${String(e)})`);
    62	    }
    63	    const actual = gitBlobSha1(bytes);
    64	    if (actual !== src.blobSha1) {
    65	      throw new Error(
    66	        `E2 corpus HARD BLOCK: content drift in ${src.path} — manifest pins ${src.blobSha1}, bytes hash to ${actual}. ` +
    67	          `Changing the corpus requires a NEW pre-registration (docs/e2-rag-preregistration.md A1).`,
    68	      );
    69	    }
    70	  }
    71	  const manifested = new Set(pins.sources.map((s) => s.path));
    72	  for (const found of walkFiles(repoRoot, pins.exhaustiveDir)) {
    73	    if (!manifested.has(found)) {
    74	      throw new Error(
    75	        `E2 corpus HARD BLOCK: unmanifested file in the pinned schema tree: ${found} — additions are drift (A1).`,
    76	      );
    77	    }
    78	  }
    79	  return pins.sources;
    80	}
