   186	    expect(() => verifyAndExecute(request, decision, opts)).toThrow(ReplayError);
   187	  });
   188	
   189	  it("REPLAY ACROSS REQUESTS: a consumed nonce blocks a different request sharing it", () => {
   190	    const { request, decision, opts } = freshFlow("n-t7");
   191	    verifyAndExecute(request, decision, opts);
   192	    const second = createApprovalRequest({ ...crewRecord, caseId: "int-second" }, { clock: fixedClock(T0), ttlMs: TTL, nonce: "n-t7" });
   193	    const secondDecision = signDecision(second, "approve", owner.privateKey, "owner-key-1", fixedClock(T0 + 1));
   194	    expect(() => verifyAndExecute(second, secondDecision, opts)).toThrow(ReplayError);
   195	  });
   196	
   197	  it("EXPIRY: valid 1ms before the boundary, expired AT it, expired after it (injected clock)", () => {
   198	    const mk = (nonce: string) => {
   199	      const request = createApprovalRequest(crewRecord, { clock: fixedClock(T0), ttlMs: TTL, nonce });
   200	      const decision = signDecision(request, "approve", owner.privateKey, "owner-key-1", fixedClock(T0 + 1));
   201	      return { request, decision };
   202	    };
   203	    const base = { authorizedSigners: ROSTER, requiredRole: "approver" } as const;
   204	    const a = mk("n-t8a");
