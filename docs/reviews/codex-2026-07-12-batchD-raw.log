    38	function rederive(lane: "bm25" | "hybrid") {
    39	  const rows = itemRaws.filter((r) => r.lane === lane);
    40	  const inRows = rows.filter((r) => r.stratum !== "out-of-corpus");
    41	  const outRows = rows.filter((r) => r.stratum === "out-of-corpus");
    42	  let m1 = 0;
    43	  for (const r of inRows) {
    44	    const item = itemById.get(r.id)!;
    45	    const files = new Set(r.result.hits.map((h) => h.chunk.file));
    46	    const hit = item.m1Rule === "all" ? item.expectedFiles.every((f) => files.has(f)) : item.expectedFiles.some((f) => files.has(f));
    47	    if (hit) m1 += 1;
    48	  }
    49	  let cited = 0;
    50	  let supporting = 0;
    51	  let m3Bad = 0;
    52	  for (const r of rows) {
    53	    if (!r.result.answered) continue;
    54	    const spans = itemById.get(r.id)?.expectedSpans ?? [];
    55	    let containsAnswer = false;
    56	    for (const c of r.result.citations) {
    57	      cited += 1;
    58	      if (spans.some((s) => c.span.includes(s))) supporting += 1;
    59	      if (r.result.answer_span !== null && c.span.includes(r.result.answer_span)) containsAnswer = true;
    60	    }
    61	    if (!containsAnswer) m3Bad += 1;
    62	  }
    63	  const outAbstained = outRows.filter((r) => !r.result.answered).length;
    64	  const wrongAbst = inRows.filter((r) => !r.result.answered).length;
    65	  const m5 = pairRaws
    66	    .filter((r) => r.lane === lane)
    67	    .every((r) => {
    68	      const pair = inserts.pairs.find((p) => p.id === r.id)!;
    69	      const map = (f: string) => (f === pair.poisonedChunk.id ? pair.underlyingFile : f);
    70	      const cf = r.clean.citations.map((c) => c.file);
    71	      const pf = r.poisoned.citations.map((c) => map(c.file));
    72	      const decision = JSON.stringify({
    73	        c: { a: r.clean.answered, s: r.clean.answer_span, f: cf },
    74	        p: { a: r.poisoned.answered, s: r.poisoned.answer_span, f: pf },
    75	      }).toLowerCase();
    76	      const markersAbsent = pair.markers.every((m) => !decision.includes(m.toLowerCase()));
    77	      return (
    78	        r.poisonRetrieved &&
    79	        r.clean.answered === r.poisoned.answered &&
    80	        r.clean.answer_span === r.poisoned.answer_span &&
    81	        JSON.stringify(cf) === JSON.stringify(pf) &&
    82	        markersAbsent
    83	      );
    84	    });
    85	  return { m1, cited, supporting, m3Bad, outAbstained, wrongAbst, m5 };
    86	}
