     2	 * E3 — the NO-SEND structural proof (plan §E3): a transitive import-graph
     3	 * walk from `lib/approvals/simulator.ts` (the AC-3 walker pattern,
     4	 * `evals/tools/registry-ac3-import-graph.test.ts`) reaches NO LLM/network
     5	 * module, NO `node:child_process` (the simulator must not shell out), and —
     6	 * the E3-specific teeth — NEITHER `lib/delivery/**` NOR `lib/mcp/**` is
     7	 * reachable at all: the simulator structurally CANNOT send or transport.
     8	 * Plus the bare-`fetch(` source scan over every reachable file.
     9	 *
    10	 * Plain: we trace every road leading out of the approvals code and prove
    11	 * none of them goes anywhere near Slack, email, the network, or a shell —
    12	 * the "send" roads don't just have gates, they don't exist.
    13	 */
    14	import { existsSync, readFileSync } from "node:fs";
    15	import { join } from "node:path";
    16	import { describe, expect, it } from "vitest";
    17	
    18	const root = process.cwd();
    19	const entry = join(root, "lib", "approvals", "simulator.ts");
    20	
    21	function importsOf(file: string): string[] {
    22	  const text = readFileSync(file, "utf8");
    23	  const specs: string[] = [];
    24	  const re = /(?:from\s+|import\s*\(\s*|import\s+)["']([^"']+)["']/g;
    25	  for (let m = re.exec(text); m; m = re.exec(text)) specs.push(m[1]);
    26	  return specs;
    27	}
    28	
    29	function resolve(fromFile: string, spec: string): string | null {
    30	  let base: string | null = null;
    31	  if (spec.startsWith("@/")) base = join(root, spec.slice(2));
    32	  else if (spec.startsWith(".")) base = join(fromFile, "..", spec);
    33	  if (base === null) return null;
    34	  const candidates = [base, `${base}.ts`, `${base}.tsx`, `${base}.mjs`, `${base}.json`, join(base, "index.ts")];
    35	  return candidates.find((c) => existsSync(c) && /\.(ts|tsx|mjs|json)$/.test(c)) ?? null;
    36	}
    37	
    38	function reachableFrom(startFile: string): Set<string> {
    39	  const queue = [startFile];
    40	  const seen = new Set<string>();
    41	  while (queue.length > 0) {
    42	    const file = queue.pop() as string;
    43	    if (seen.has(file)) continue;
    44	    seen.add(file);
    45	    if (file.endsWith(".json")) continue;
    46	    for (const spec of importsOf(file)) {
    47	      const resolved = resolve(file, spec);
    48	      if (resolved !== null) queue.push(resolved);
    49	    }
    50	  }
    51	  return seen;
    52	}
