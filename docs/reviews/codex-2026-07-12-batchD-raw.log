    54	// The AC-3 ban list, EXTENDED per the E3 packet: + node:child_process.
    55	const banned = [
    56	  /lib\/agents\//,
    57	  /@ai-sdk/,
    58	  /^ai$|\/ai\//,
    59	  /node:https?/,
    60	  /undici/,
    61	  /groq|gemini/i,
    62	  /node:net|node:tls|node:dgram/,
    63	  /^node-fetch|^axios|^got$|^ws$/,
    64	  /node:child_process/,
    65	];
    66	
    67	describe("E3 no-send structural proof", () => {
    68	  const reached = reachableFrom(entry);
    69	  const rel = [...reached].map((f) => f.replace(root, ""));
    70	
    71	  it("no module reachable from lib/approvals/simulator.ts matches a banned LLM/network/shell pattern", () => {
    72	    for (const file of reached) {
    73	      if (file.endsWith(".json")) continue;
    74	      for (const spec of importsOf(file)) {
    75	        for (const pattern of banned) {
    76	          expect(pattern.test(spec), `banned import "${spec}" in ${file}`).toBe(false);
    77	        }
    78	      }
    79	    }
    80	  });
    81	
    82	  it("lib/delivery/** is UNREACHABLE (the simulator cannot build a sendable payload)", () => {
    83	    expect(rel.some((f) => /^\/lib\/delivery\//.test(f))).toBe(false);
    84	  });
    85	
    86	  it("lib/mcp/** is UNREACHABLE (the simulator is not a transport surface)", () => {
    87	    expect(rel.some((f) => /^\/lib\/mcp\//.test(f))).toBe(false);
    88	  });
    89	
    90	  it("no reachable source performs a bare fetch()", () => {
    91	    for (const file of reached) {
    92	      if (file.endsWith(".json")) continue;
    93	      const text = readFileSync(file, "utf8");
    94	      expect(/(^|[^.\w])fetch\s*\(/.test(text), `bare fetch( reachable in ${file}`).toBe(false);
    95	    }
    96	  });
    97	
    98	  it("sanity: the walk actually traversed the approvals module (types + canonical + crew types)", () => {
