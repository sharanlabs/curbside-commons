    57	/** Read this repo's own `package.json` `version` (never hand-duplicated). */
    58	function readPackageVersion(): string {
    59	  const pkgPath = join(HERE, "..", "..", "package.json");
    60	  const raw = readFileSync(pkgPath, "utf8");
    61	  const pkg = JSON.parse(raw) as { version?: unknown };
    62	  if (typeof pkg.version !== "string" || pkg.version.length === 0) {
    63	    throw new Error(`lib/mcp/server.ts: package.json at ${pkgPath} has no non-empty string "version"`);
    64	  }
    65	  return pkg.version;
    66	}
    67	
    68	/** Server `instructions` string surfaced to the client at `initialize` (plan §5 row A1). */
    69	const SERVER_INSTRUCTIONS =
    70	  "commerce-truth-audit MCP server — SIMULATED demonstration data throughout, never real " +
    71	  "merchant data. Deterministic, $0, offline engine underneath every tool: agents recommend, " +
    72	  "the engine decides (no AI call sits in any of these seven tools' decision paths). run_demo is " +
    73	  "a demo_only walkthrough, never an audit result. classify_and_audit is advisory — candidate " +
    74	  "leads, never a verdict; its classifier has not earned a calibrated label (earnsLabel: false). " +
    75	  "lookup_reference is advisory + experimental — extractive reference retrieval whose " +
    76	  "pre-registered floors were NOT met (docs/e2-rag-preregistration.md RESULTS); it cites or " +
    77	  "abstains, never decides.";
    78	
    79	/** The tool names (six engine tools + lookup_reference), in the A0 registry's own definition order (never hand-duplicated). */
    80	const TOOL_ORDER: readonly string[] = Object.freeze([...TOOLS.keys()]);
    81	
    82	/** One `tools/list` entry: name + committed description + the VERBATIM committed input schema. */
    83	interface McpToolDescriptor {
    84	  readonly name: string;
    85	  readonly description: string;
    86	  readonly inputSchema: Readonly<Record<string, unknown>>;
    87	}
    88	
    89	function listedTools(): McpToolDescriptor[] {
    90	  return TOOL_ORDER.map((name) => {
    91	    const meta = TOOLS.get(name);
    92	    if (!meta) {
    93	      // Unreachable in practice — TOOL_ORDER is derived from TOOLS itself.
    94	      throw new Error(`lib/mcp/server.ts: tool "${name}" listed but not found in the registry`);
    95	    }
    96	    const description = TOOL_DESCRIPTIONS[name];
    97	    if (description === undefined) {
    98	      throw new Error(`lib/mcp/server.ts: tool "${name}" has no committed MCP description`);
    99	    }
   100	    return { name: meta.name, description, inputSchema: meta.inputSchema };
   101	  });
   102	}
   103	
   104	/**
   105	 * Build the `structuredContent` machine-readable slot for one tool result.
   106	 *
   107	 * `structuredContent` (not `_meta`) is the SDK-sanctioned slot chosen here:
   108	 * the SDK's own `CallToolResultSchema` defines `structuredContent` as a
   109	 * `Record<string, unknown>` specifically for a tool's machine-readable
   110	 * output, so every MCP client library already knows to look there for
   111	 * tool-domain data. `_meta` is the protocol's own out-of-band envelope
   112	 * (progress tokens, related-task ids) — reserved for transport/protocol
   113	 * concerns, not tool-domain honesty flags. The shape is FIXED (every key
   114	 * always present) so a client never has to branch on which keys exist;
   115	 * `earnsLabel` is `null` (not omitted) when a tool carries no advisory
   116	 * classifier at all, so its presence/absence is never itself a signal a
   117	 * caller has to special-case.
   118	 */
   119	function structuredContentFor(result: ToolResult): Record<string, unknown> {
   120	  return {
   121	    tool: result.tool,
   122	    ok: result.ok,
   123	    exitCode: result.exitCode,
   124	    demoOnly: result.demoOnly === true,
   125	    advisory: result.advisory === true,
   126	    earnsLabel: result.earnsLabel ?? null,
   127	  };
   128	}
   129	
   130	/** Format one ajv error object as a stable "<json-pointer> <message>" fragment. */
   131	function formatAjvError(err: { readonly instancePath?: string; readonly message?: string }): string {
   132	  const pointer = err.instancePath !== undefined && err.instancePath.length > 0 ? err.instancePath : "(root)";
   133	  return `${pointer} ${err.message ?? "invalid"}`;
   134	}
   135	
   136	/**
   137	 * Run one tool via the registry's ONE execution path (`callTool`) and map its
   138	 * outcome to an MCP `CallToolResult`.
   139	 *
   140	 * `exitCode !== 0` is NOT an MCP error — the audit ran fine and reported
   141	 * findings, which is a successful tool call (`isError: false`). Only a
   142	 * genuine failure to run the tool at all — bad input (`ToolInputError`), an
   143	 * unregistered name (`ToolNotFoundError`, unreachable through this server's
   144	 * own `tools/list` contract but mapped anyway per the dispatch packet), or an
   145	 * engine-level failure (`StatementParseError`, an unreadable file, an unknown
   146	 * `ruleId` via `RuleNotFoundError`) — becomes `isError: true`. No branch here
   147	 * ever swallows a failure into a silent success.
   148	 */
   149	function toolCallResult(name: string, rawArgs: unknown): CallToolResult {
   150	  try {
   151	    const result = callTool(name, rawArgs ?? {});
   152	    return {
   153	      content: [{ type: "text", text: result.canonical }],
   154	      structuredContent: structuredContentFor(result),
   155	      isError: false,
   156	    };
   157	  } catch (err) {
   158	    if (err instanceof ToolInputError) {
   159	      const detail = err.ajvErrors.map(formatAjvError).join("; ");
   160	      return {
   161	        content: [
   162	          {
   163	            type: "text",
   164	            text: `tool "${name}": input failed schema validation (${err.ajvErrors.length} error(s)): ${detail}`,
   165	          },
   166	        ],
   167	        isError: true,
   168	      };
   169	    }
   170	    if (err instanceof ToolNotFoundError) {
   171	      // Unreachable via a well-behaved MCP client (this server's own
   172	      // `tools/list` never advertises a name outside TOOL_ORDER), but a raw
   173	      // `tools/call` with an arbitrary `name` is still possible over the
   174	      // wire, so this stays mapped rather than left to throw uncaught.
   175	      return { content: [{ type: "text", text: err.message }], isError: true };
   176	    }
   177	    const message = err instanceof Error ? err.message : String(err);
   178	    return { content: [{ type: "text", text: message }], isError: true };
   179	  }
   180	}
   181	
   182	/**
   183	 * Build a fresh, UNCONNECTED `Server` instance exposing all of the A0
   184	 * registry's tools over MCP. The caller (`bin/mcp-server.mjs`) attaches the stdio
   185	 * transport and calls `connect`.
   186	 */
   187	export function createMcpServer(): Server {
   188	  const server = new Server(
   189	    { name: "commerce-truth-audit", version: readPackageVersion() },
   190	    {
   191	      capabilities: { tools: {} },
   192	      instructions: SERVER_INSTRUCTIONS,
   193	    },
   194	  );
   195	
   196	  server.setRequestHandler(ListToolsRequestSchema, () => ({
   197	    tools: listedTools() as unknown as Tool[],
   198	  }));
   199	
   200	  server.setRequestHandler(CallToolRequestSchema, (request) => {
   201	    const { name, arguments: args } = request.params;
   202	    return toolCallResult(name, args);
   203	  });
   204	
   205	  return server;
   206	}
   207	
   208	export { TOOL_ORDER };
