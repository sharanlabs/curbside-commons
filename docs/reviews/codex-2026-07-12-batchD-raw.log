   210	      verifyAndExecute(b.request, b.decision, { ...base, clock: fixedClock(T0 + TTL), seenNonces: new Set() }),
   211	    ).toThrow(ExpiredError);
   212	    const c = mk("n-t8c");
   213	    expect(() =>
   214	      verifyAndExecute(c.request, c.decision, { ...base, clock: fixedClock(T0 + TTL + 60_000), seenNonces: new Set() }),
   215	    ).toThrow(ExpiredError);
   216	  });
   217	
